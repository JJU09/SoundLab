---
// FM 합성 위젯 — 캐리어를 모듈레이터로 주파수 변조해 측대역(sideband)을 만든다.
//   modulator(sine, f_m) → modGain(β·f_m) → carrier.frequency
//   carrier(sine, f_c) → out → core.input
// C:M 비율이 음색 종류(정수=조화, 비정수=금속), 변조 인덱스 β가 측대역 풍부함을 결정.
// widgetConfig: carrier(f_c Hz), ratio(M/C), index(β).
interface Props {
  config?: Record<string, any>;
}
const { config = {} } = Astro.props;
const fc = config.carrier ?? 220;
const ratio = config.ratio ?? 1;
const index = config.index ?? 0;
const adv = (tier?: string) => (tier && tier !== 'easy' ? { 'data-adv': tier } : {});
---
<div class="fm-widget rounded-2xl border border-[var(--color-border)] bg-white overflow-hidden"
  data-carrier={fc} data-ratio={ratio} data-index={index}>

  <div class="flex items-center justify-between px-5 py-4 border-b border-[var(--color-border)] bg-[var(--color-surface)]">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg flex items-center justify-center gradient-brand">
        <svg class="text-white" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c1.5 0 1.5-5 3-5s1.5 5 3 5M8 12c2 0 2-9 4-9s2 18 4 18 2-9 4-9"/></svg>
      </div>
      <div>
        <span class="font-bold text-base" style="font-family:'Space Grotesk','Pretendard',sans-serif">FM 합성</span>
        <span class="text-sm text-[var(--color-ink-300)] ml-2">FM Synthesis</span>
      </div>
    </div>
    <button class="play-btn gradient-brand text-white text-sm font-semibold px-4 py-1.5 rounded-full transition hover:opacity-90" style="font-family:'Space Grotesk','Pretendard',sans-serif">▶ 소리 켜기</button>
  </div>

  <div class="p-5 space-y-4">
    <!-- 파형 -->
    <div class="relative rounded-xl overflow-hidden bg-[var(--color-surface-2)] border border-[var(--color-border)]">
      <canvas class="scope-cv block w-full" style="height:104px"></canvas>
      <span class="absolute top-2 left-2.5 text-[10px] font-mono uppercase tracking-wider text-[var(--color-violet)] opacity-70">Waveform · 파형</span>
    </div>
    <!-- 스펙트럼 (측대역) -->
    <div class="relative rounded-xl overflow-hidden bg-[var(--color-surface-2)] border border-[var(--color-border)]">
      <canvas class="spec-cv block w-full" style="height:84px"></canvas>
      <span class="absolute top-2 left-2.5 text-[10px] font-mono uppercase tracking-wider text-[var(--color-blue)] opacity-70">Spectrum · 측대역(sideband)</span>
    </div>

    <!-- 변조 인덱스 (전 티어 — easy의 단일 손잡이) -->
    <div>
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">Index · 변조 세기 (β)</span>
        <span class="idx-val text-sm font-mono text-[var(--color-ink-700)]">{index}</span>
      </div>
      <input type="range" class="sl-range idx-range" min="0" max="12" step="0.1" value={index} aria-label="변조 인덱스" />
    </div>

    <!-- C:M 비율 (normal↑) -->
    <div {...adv('normal')}>
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">Ratio · C:M 비율</span>
        <span class="ratio-val text-sm font-mono text-[var(--color-ink-700)]">1 : {ratio}</span>
      </div>
      <input type="range" class="sl-range ratio-range" min="0.5" max="5" step="0.25" value={ratio} aria-label="C M 비율" />
      <span class="ratio-kind block mt-1 text-[10px] font-mono text-[var(--color-ink-300)]">정수배 → 조화(harmonic) 음색</span>
    </div>

    <!-- 캐리어 주파수 (normal↑) -->
    <div {...adv('normal')}>
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">Carrier · 캐리어(음높이)</span>
        <span class="fc-val text-sm font-mono text-[var(--color-ink-700)]">{fc}Hz</span>
      </div>
      <input type="range" class="sl-range fc-range" min="110" max="440" step="1" value={fc} aria-label="캐리어 주파수" />
    </div>
  </div>
</div>

<script>
import { AudioCore } from '../audio/core';

function initFm(root: HTMLElement) {
  const core = new AudioCore();
  let fc = Number(root.dataset.carrier) || 220;
  let ratio = Number(root.dataset.ratio) || 1;
  let index = Number(root.dataset.index) || 0;
  let playing = false;

  const out = core.gain(0.5); out.connect(core.input);
  let carrier: OscillatorNode | null = null;
  let modulator: OscillatorNode | null = null;
  let modGain: GainNode | null = null;

  const fm = () => fc * ratio; // 모듈레이터 주파수
  // 변조 깊이(Hz) = β · f_m. modGain이 carrier.frequency를 ±이만큼 흔듦.
  function applyMod() {
    if (!modulator || !modGain) return;
    core.smooth(modulator.frequency, fm());
    core.smooth(modGain.gain, index * fm());
  }

  async function start() {
    await core.resume();
    carrier = core.ctx.createOscillator(); carrier.type = 'sine'; carrier.frequency.value = fc;
    modulator = core.ctx.createOscillator(); modulator.type = 'sine'; modulator.frequency.value = fm();
    modGain = core.gain(index * fm());
    modulator.connect(modGain); modGain.connect(carrier.frequency); // 주파수 변조
    carrier.connect(out);
    carrier.start(); modulator.start();
    playing = true;
  }
  function stop() {
    [carrier, modulator].forEach(o => { if (o) { try { o.stop(); } catch (e) {} o.disconnect(); } });
    if (modGain) modGain.disconnect();
    carrier = modulator = null; modGain = null; playing = false;
  }

  // ── 시각화 ──
  const scope = root.querySelector('.scope-cv') as HTMLCanvasElement;
  const spec = root.querySelector('.spec-cv') as HTMLCanvasElement;
  const fit = (cv: HTMLCanvasElement) => { const r = cv.getBoundingClientRect(); cv.width = Math.max(1, r.width * devicePixelRatio); cv.height = Math.max(1, r.height * devicePixelRatio); };
  fit(scope); fit(spec);
  addEventListener('resize', () => { fit(scope); fit(spec); });

  const td = new Uint8Array(core.analyser.fftSize);
  const fd = new Uint8Array(core.analyser.frequencyBinCount);
  function draw() {
    requestAnimationFrame(draw);
    let ctx = scope.getContext('2d')!; let W = scope.width, H = scope.height;
    core.analyser.getByteTimeDomainData(td);
    ctx.clearRect(0, 0, W, H); ctx.beginPath();
    for (let i = 0; i < td.length; i++) { const x = (i / td.length) * W, y = (td[i] / 255) * H; i ? ctx.lineTo(x, y) : ctx.moveTo(x, y); }
    ctx.strokeStyle = '#7c3aed'; ctx.lineWidth = 1.6 * devicePixelRatio; ctx.stroke();
    // 스펙트럼 — 측대역이 보이도록 저역 ~3kHz까지
    ctx = spec.getContext('2d')!; W = spec.width; H = spec.height;
    core.analyser.getByteFrequencyData(fd);
    ctx.clearRect(0, 0, W, H);
    const bins = 140, bw = W / bins;
    for (let i = 0; i < bins; i++) {
      const v = fd[i] / 255, bh = v * H;
      ctx.fillStyle = `rgba(37,99,235,${0.35 + v * 0.5})`;
      ctx.fillRect(i * bw, H - bh, bw * 0.8, bh);
    }
  }
  draw();

  // ── 컨트롤 ──
  const setPct = (el: HTMLInputElement) => el.style.setProperty('--sl-pct', ((+el.value - +el.min) / (+el.max - +el.min) * 100) + '%');

  const playBtn = root.querySelector('.play-btn') as HTMLButtonElement;
  playBtn.addEventListener('click', async () => {
    if (playing) { stop(); playBtn.textContent = '▶ 소리 켜기'; }
    else { await start(); playBtn.textContent = '⏸ 소리 끄기'; }
  });

  const idxRange = root.querySelector('.idx-range') as HTMLInputElement;
  const idxVal = root.querySelector('.idx-val') as HTMLElement;
  setPct(idxRange);
  idxRange.addEventListener('input', () => {
    index = +idxRange.value; idxVal.textContent = index.toFixed(1); setPct(idxRange);
    if (modGain) core.smooth(modGain.gain, index * fm());
  });

  const ratioRange = root.querySelector('.ratio-range') as HTMLInputElement;
  const ratioVal = root.querySelector('.ratio-val') as HTMLElement;
  const ratioKind = root.querySelector('.ratio-kind') as HTMLElement;
  setPct(ratioRange);
  ratioRange.addEventListener('input', () => {
    ratio = +ratioRange.value; ratioVal.textContent = '1 : ' + ratio; setPct(ratioRange);
    const harmonic = Number.isInteger(ratio);
    ratioKind.textContent = harmonic ? '정수배 → 조화(harmonic) 음색' : '비정수배 → 비조화·금속(metallic) 음색';
    applyMod();
  });

  const fcRange = root.querySelector('.fc-range') as HTMLInputElement;
  const fcVal = root.querySelector('.fc-val') as HTMLElement;
  setPct(fcRange);
  fcRange.addEventListener('input', () => {
    fc = +fcRange.value; fcVal.textContent = fc + 'Hz'; setPct(fcRange);
    if (carrier) core.smooth(carrier.frequency, fc);
    applyMod();
  });
}

document.querySelectorAll<HTMLElement>('.fm-widget').forEach(initFm);
</script>
