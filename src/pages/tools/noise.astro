---
import Base from '../../layouts/Base.astro';
const base = import.meta.env.BASE_URL;
const desc = '화이트·핑크·브라운 노이즈를 재생하는 무료 온라인 노이즈 제너레이터. 집중·공부·수면·이명 완화용. 볼륨 조절과 자동 종료 타이머 내장. 설치 없이 브라우저에서.';
---
<Base title="노이즈 제너레이터" description={desc} type="website">

<div class="max-w-xl mx-auto px-4 sm:px-6 py-12">
  <nav class="flex items-center gap-2 text-xs font-mono text-[var(--color-ink-300)] mb-6">
    <a href={base} class="hover:text-[var(--color-violet)] transition">홈</a><span>/</span>
    <a href={`${base}tools/`} class="hover:text-[var(--color-violet)] transition">도구</a><span>/</span>
    <span class="text-[var(--color-ink-700)]">노이즈 제너레이터</span>
  </nav>

  <div class="mb-6">
    <span class="text-xs font-mono px-2.5 py-1 rounded-full border border-[var(--color-violet-light)] text-[var(--color-violet)] bg-[var(--color-violet-glow)]">TOOLS</span>
    <h1 class="text-3xl font-bold mt-3 mb-2" style="font-family:'Space Grotesk','Pretendard',sans-serif">노이즈 제너레이터</h1>
    <p class="text-[var(--color-ink-500)]">집중·공부·수면·이명 완화에. 노이즈 종류를 고르고 재생하세요. 자동 종료 타이머 내장.</p>
  </div>

  <div class="noise rounded-2xl border border-[var(--color-border)] bg-white overflow-hidden">
    <div class="p-6 sm:p-8 space-y-6">
      <!-- 노이즈 종류 -->
      <div class="grid grid-cols-3 gap-2">
        {[['white','화이트','밝고 쉭쉭'],['pink','핑크','균형·자연','1'],['brown','브라운','깊고 묵직']].map(([v,t,d,def]) => (
          <button class="type-btn p-3 rounded-xl border border-[var(--color-border)] bg-white text-center transition hover:border-[var(--color-violet)]" data-type={v} aria-pressed={def?'true':'false'}>
            <div class="text-sm font-bold text-[var(--color-ink-700)]" style="font-family:'Space Grotesk','Pretendard',sans-serif">{t}</div>
            <div class="text-[10px] text-[var(--color-ink-300)] mt-0.5">{d}</div>
          </button>
        ))}
      </div>

      <!-- 재생 -->
      <button class="play-btn w-full gradient-brand text-white font-semibold py-4 rounded-xl text-lg flex items-center justify-center gap-2 transition hover:opacity-90" style="font-family:'Space Grotesk','Pretendard',sans-serif">
        <span class="play-dot w-2.5 h-2.5 rounded-full bg-white"></span><span class="play-label">▶ 재생</span>
      </button>

      <!-- 볼륨 -->
      <div>
        <div class="flex items-center justify-between mb-1">
          <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">Volume</span>
          <span class="vol-val text-sm font-mono text-[var(--color-ink-700)]">40%</span>
        </div>
        <input type="range" class="sl-range vol-range w-full" min="0" max="100" step="1" value="40" aria-label="볼륨" />
      </div>

      <!-- 톤 (부드럽게 ↔ 선명) -->
      <div>
        <div class="flex items-center justify-between mb-1">
          <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">Tone · 음색</span>
          <span class="tone-val text-sm font-mono text-[var(--color-ink-700)]">선명</span>
        </div>
        <input type="range" class="sl-range tone-range w-full" min="0" max="1000" step="1" value="1000" aria-label="톤(부드럽게/선명)" />
        <div class="flex justify-between text-[10px] font-mono text-[var(--color-ink-300)] mt-1 px-0.5"><span>부드럽게</span><span>선명</span></div>
      </div>

      <!-- 타이머 -->
      <div>
        <div class="flex items-center justify-between mb-1.5">
          <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">자동 종료</span>
          <span class="timer-left text-sm font-mono text-[var(--color-violet)]"></span>
        </div>
        <div class="flex gap-1 p-1 bg-[var(--color-surface-2)] rounded-xl" role="group" aria-label="타이머">
          {[['0','끄기'],['15','15분'],['30','30분'],['60','60분']].map(([v,t]) => (
            <button class="timer-btn flex-1 px-2 py-1.5 rounded-lg text-xs font-semibold transition-all text-[var(--color-ink-500)]" data-min={v} aria-pressed={v==='0'?'true':'false'} style="font-family:'Space Grotesk','Pretendard',sans-serif">{t}</button>
          ))}
        </div>
      </div>
    </div>
  </div>

  <p class="text-xs text-[var(--color-ink-300)] mt-4 text-center">화이트=전 대역 균등 · 핑크=옥타브당 균등(자연스러움) · 브라운=저음 강조(가장 부드러움) · 편하게 들리는 볼륨으로</p>

  <div class="mt-8 p-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] text-sm text-[var(--color-ink-500)]">
    노이즈가 어떻게 소리가 되는지, 화이트 vs 핑크의 차이는 <a href={`${base}learn/acoustics/tone/`} class="text-[var(--color-violet)] font-medium hover:underline">소리의 3요소</a>와
    <a href={`${base}learn/digital/bitdepth/`} class="text-[var(--color-violet)] font-medium hover:underline">비트 뎁스</a>에서.
  </div>
</div>

<script>
import { AudioCore } from '../../audio/core';

function initNoise(root: HTMLElement) {
  const core = new AudioCore();
  let type = 'pink', playing = false, vol = 40;
  const out = core.gain(vol / 100 * 0.6); out.connect(core.input);
  // 톤 = 로우패스. 컷오프 낮추면 고음이 깎여 부드럽고 먹먹하게(빗소리·먼 파도 느낌).
  const lpf = core.ctx.createBiquadFilter(); lpf.type = 'lowpass'; lpf.frequency.value = 20000; lpf.Q.value = 0.7;
  lpf.connect(out);
  let src: AudioBufferSourceNode | null = null;
  const cache: Record<string, AudioBuffer> = {};

  function buildBuf(t: string): AudioBuffer {
    if (cache[t]) return cache[t];
    const len = core.ctx.sampleRate * 2, b = core.ctx.createBuffer(1, len, core.ctx.sampleRate), d = b.getChannelData(0);
    if (t === 'white') {
      for (let i = 0; i < len; i++) d[i] = (Math.random() * 2 - 1) * 0.5;
    } else if (t === 'brown') {
      let last = 0;
      for (let i = 0; i < len; i++) { const w = Math.random() * 2 - 1; last = (last + 0.02 * w) / 1.02; d[i] = last * 3.5; }
    } else { // pink (Paul Kellet)
      let b0=0,b1=0,b2=0,b3=0,b4=0,b5=0,b6=0;
      for (let i=0;i<len;i++){ const w=Math.random()*2-1;
        b0=0.99886*b0+w*0.0555179; b1=0.99332*b1+w*0.0750759; b2=0.96900*b2+w*0.1538520;
        b3=0.86650*b3+w*0.3104856; b4=0.55000*b4+w*0.5329522; b5=-0.7616*b5-w*0.0168980;
        d[i]=(b0+b1+b2+b3+b4+b5+b6+w*0.5362)*0.11; b6=w*0.115926; }
    }
    cache[t] = b; return b;
  }
  async function startSrc() {
    await core.resume();
    if (src) { try { src.stop(); } catch (e) {} src.disconnect(); }
    src = core.ctx.createBufferSource(); src.buffer = buildBuf(type); src.loop = true; src.connect(lpf); src.start();
  }
  function stopSrc() { if (src) { try { src.stop(); } catch (e) {} src.disconnect(); src = null; } }

  // ── 타이머 ──
  let timerMin = 0, timerEnd = 0, tick: ReturnType<typeof setInterval> | null = null;
  const leftEl = root.querySelector('.timer-left') as HTMLElement;
  function fmtLeft(ms: number) { const s = Math.max(0, Math.ceil(ms / 1000)); return Math.floor(s / 60) + ':' + String(s % 60).padStart(2, '0'); }
  function startTick() {
    if (tick) clearInterval(tick);
    if (!playing || timerMin === 0) { leftEl.textContent = ''; return; }
    timerEnd = Date.now() + timerMin * 60000;
    tick = setInterval(() => {
      const ms = timerEnd - Date.now();
      if (ms <= 0) { setPlaying(false); return; }
      leftEl.textContent = fmtLeft(ms) + ' 남음';
    }, 500);
    leftEl.textContent = fmtLeft(timerMin * 60000) + ' 남음';
  }

  // ── 재생 상태 ──
  const playBtn = root.querySelector('.play-btn') as HTMLButtonElement;
  const playDot = root.querySelector('.play-dot') as HTMLElement;
  const playLabel = root.querySelector('.play-label') as HTMLElement;
  async function setPlaying(on: boolean) {
    playing = on;
    if (on) { await startSrc(); playBtn.style.cssText = 'background:var(--color-surface-2);color:var(--color-ink-700)'; playDot.style.cssText = 'background:#ef4444;box-shadow:0 0 8px #ef4444'; playLabel.textContent = '■ 정지'; startTick(); }
    else { stopSrc(); if (tick) clearInterval(tick); leftEl.textContent = ''; playBtn.style.cssText = ''; playDot.style.cssText = 'background:white'; playLabel.textContent = '▶ 재생'; }
  }
  playBtn.addEventListener('click', () => setPlaying(!playing));

  // 종류
  const typeBtns = [...root.querySelectorAll<HTMLElement>('.type-btn')];
  typeBtns.forEach(btn => {
    const on = () => btn.style.cssText = 'border-color:var(--color-violet);background:var(--color-violet-glow)';
    btn.addEventListener('click', () => {
      typeBtns.forEach(b => { b.setAttribute('aria-pressed','false'); b.style.cssText=''; });
      btn.setAttribute('aria-pressed','true'); on();
      type = btn.dataset.type!;
      if (playing) startSrc(); // 끊김 없이 교체
    });
    if (btn.getAttribute('aria-pressed') === 'true') on();
  });

  // 볼륨
  const volRange = root.querySelector('.vol-range') as HTMLInputElement;
  const volVal = root.querySelector('.vol-val') as HTMLElement;
  volRange.style.setProperty('--sl-pct', vol + '%');
  volRange.addEventListener('input', () => {
    vol = +volRange.value; volVal.textContent = vol + '%';
    volRange.style.setProperty('--sl-pct', vol + '%');
    core.smooth(out.gain, vol / 100 * 0.6);
  });

  // 톤(로우패스 컷오프) — 300Hz~20kHz 로그
  const toneRange = root.querySelector('.tone-range') as HTMLInputElement;
  const toneVal = root.querySelector('.tone-val') as HTMLElement;
  toneRange.style.setProperty('--sl-pct', '100%');
  toneRange.addEventListener('input', () => {
    const p = +toneRange.value, hz = Math.round(300 * Math.pow(20000 / 300, p / 1000));
    toneRange.style.setProperty('--sl-pct', (p / 10) + '%');
    toneVal.textContent = p >= 990 ? '선명' : p <= 20 ? '부드럽게' : (hz >= 1000 ? (hz / 1000).toFixed(1) + 'kHz' : hz + 'Hz');
    core.smooth(lpf.frequency, hz, 0.03);
  });

  // 타이머 버튼
  const timerBtns = [...root.querySelectorAll<HTMLElement>('.timer-btn')];
  timerBtns.forEach(btn => {
    const on = () => btn.style.cssText = 'background:white;color:var(--color-violet);box-shadow:0 1px 4px rgba(0,0,0,0.08)';
    btn.addEventListener('click', () => {
      timerBtns.forEach(b => { b.setAttribute('aria-pressed','false'); b.style.cssText=''; });
      btn.setAttribute('aria-pressed','true'); on();
      timerMin = Number(btn.dataset.min); startTick();
    });
    if (btn.getAttribute('aria-pressed') === 'true') on();
  });
}

document.querySelectorAll<HTMLElement>('.noise').forEach(initNoise);
</script>

</Base>
