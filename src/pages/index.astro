---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { HUB_META, HUBS } from '../content.config';
const base = import.meta.env.BASE_URL;

const all = (await getCollection('topics')).filter(t => !t.data.draft);
const hubs = [...HUBS]
  .sort((a, b) => HUB_META[a].order - HUB_META[b].order)
  .map(h => ({ id: h, ...HUB_META[h], count: all.filter(t => t.data.hub === h).length }));

// 홈 쇼케이스 — 샌드박스/도구 (각 섹션 전체 보기로 연결)
const sandboxes = [
  { name: '모듈러 페달보드', hub: '이펙트', path: 'sandbox/effects/', desc: '이펙터를 쌓고 순서 바꾸기', icon: 'M5 8h2.5l2 8 2.5-12 2 8 2-4H19' },
  { name: '미니 믹서', hub: '믹싱', path: 'sandbox/mixer/', desc: '트랙 밸런스·EQ·컴프', icon: 'M6 4v16 M12 4v16 M18 4v16 M3.5 9h5 M9.5 14h5 M15.5 7h5' },
  { name: '신디사이저', hub: '신디시스', path: 'sandbox/synth/', desc: '건반으로 연주하는 신스', icon: 'M4 14a8 8 0 0 1 16 0 M8 14v4 M11 14v4 M14 14v4 M17 14v4' },
  { name: '파동 실험실', hub: '소리와 파동', path: 'sandbox/waves/', desc: '배음·맥놀이·위상 간섭', icon: 'M3 12c2-6 4-6 6 0s4 6 6 0 4-6 6 0' },
  { name: '로파이 실험실', hub: '디지털', path: 'sandbox/lofi/', desc: '샘플레이트·비트 열화', icon: 'M4 16h3v-4h3v6h3V8h3v8h3' },
];
const tools = [
  { name: '메트로놈', path: 'tools/metronome/', desc: 'BPM·박자표·탭템포', icon: 'M9 3h6l4 18H5z M12 18l1.8-9' },
  { name: '음정·코드 청음', path: 'tools/ear-training/', desc: '청음 훈련·기록', icon: 'M9 18V5l12-2v13 M9 18a3 3 0 1 1-6 0 3 3 0 0 1 6 0z M21 16a3 3 0 1 1-6 0 3 3 0 0 1 6 0z' },
  { name: 'EQ 주파수 청음', path: 'tools/eq-ear/', desc: '믹싱 귀 훈련', icon: 'M6 4v16 M12 4v16 M18 4v16 M3.5 9h5 M9.5 13h5 M15.5 8h5' },
  { name: '크로마틱 튜너', path: 'tools/tuner/', desc: '마이크 실시간 튜닝', icon: 'M9 3v7a3 3 0 0 0 6 0V3 M12 13v8' },
  { name: '노이즈 제너레이터', path: 'tools/noise/', desc: '집중·수면·이명 완화', icon: 'M4 10v4 M8 6v12 M12 3v18 M16 6v12 M20 10v4' },
];
---
<Base title="홈" description="음향 물리부터 신디시스·이펙트·믹싱까지, Web Audio API로 듣고 만지며 배우는 인터랙티브 사운드 백과사전.">

  <!-- Hero -->
  <section class="relative max-w-6xl mx-auto px-4 sm:px-6 pt-20 pb-16 text-center overflow-hidden">
    <!-- 배경 글로우 -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full pointer-events-none"
      style="background: radial-gradient(ellipse, rgba(124,58,237,0.1) 0%, rgba(37,99,235,0.06) 50%, transparent 70%);">
    </div>

    <div class="relative">
      <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-mono font-medium mb-6
        border border-[var(--color-violet-light)] bg-[var(--color-violet-glow)] text-[var(--color-violet)]">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-violet)] animate-pulse"></span>
        Web Audio API · 무설치 · 무료
      </span>

      <h1 class="text-4xl sm:text-6xl font-bold tracking-tight mb-5 leading-tight" style="font-family:'Space Grotesk','Pretendard',sans-serif">
        소리를 <span class="gradient-brand-text">직접 만지며</span><br/>배우는 사운드 백과사전
      </h1>

      <p class="text-lg text-[var(--color-ink-500)] max-w-xl mx-auto mb-10 leading-relaxed">
        음향 물리부터 신디시스·이펙트·믹싱까지.<br/>
        노브를 돌리고 파형을 보며 사운드의 원리를 익히세요.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href={`${base}learn/`}
          class="gradient-brand text-white font-semibold px-7 py-3 rounded-xl text-[15px] transition hover:opacity-90 hover:-translate-y-0.5 shadow-lg"
          style="font-family:'Space Grotesk','Pretendard',sans-serif; box-shadow: 0 8px 30px -8px rgba(124,58,237,0.5)">
          학습 시작하기 →
        </a>
        <a href={`${base}sandbox/`}
          class="border border-[var(--color-border)] text-[var(--color-ink-700)] font-semibold px-7 py-3 rounded-xl text-[15px] transition hover:border-[var(--color-violet)] hover:text-[var(--color-violet)] bg-white"
          style="font-family:'Space Grotesk','Pretendard',sans-serif">
          샌드박스 열기
        </a>
      </div>
    </div>
  </section>

  <!-- 지식 허브 쇼케이스 -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-20">
    <div class="flex items-baseline gap-3 mb-8">
      <h2 class="text-xl font-bold" style="font-family:'Space Grotesk','Pretendard',sans-serif">5가지 지식 허브</h2>
      <span class="text-sm text-[var(--color-ink-300)] font-mono">소리 물리부터 믹싱까지 — 듣고 만지며 배우는 백과사전</span>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {hubs.map((h, i) => {
        const ready = h.count > 0;
        const inner = (
          <>
            <div class="flex items-baseline justify-between mb-3">
              <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">{h.label}</span>
              {ready
                ? <span class="text-[10px] font-mono text-[var(--color-violet)]">{h.count}개 토픽</span>
                : <span class="text-[10px] font-mono px-2 py-0.5 rounded-full bg-[var(--color-surface-2)] text-[var(--color-ink-300)]">준비 중</span>}
            </div>
            <div class="flex items-center gap-2 mb-1">
              <span class={`w-7 h-7 rounded-lg flex items-center justify-center text-xs font-mono font-bold text-white ${ready ? 'gradient-brand' : 'bg-[var(--color-ink-300)]'}`}>
                {String(i + 1).padStart(2, '0')}
              </span>
              <h3 class={`font-bold text-lg ${ready ? 'group-hover:gradient-brand-text transition' : ''}`} style="font-family:'Space Grotesk','Pretendard',sans-serif">{h.kr}</h3>
            </div>
            <p class="text-sm text-[var(--color-ink-500)] leading-relaxed">{h.desc}</p>
          </>
        );
        return ready ? (
          <a href={`${base}learn/${h.id}/`}
            class="group block p-5 rounded-2xl border border-[var(--color-border)] bg-white hover:border-transparent transition-all duration-200"
            style="--hover-color: rgba(124,58,237,0.4)"
            onmouseover="this.style.boxShadow=`0 0 0 1.5px var(--hover-color), 0 8px 30px -10px var(--hover-color)`"
            onmouseout="this.style.boxShadow=''"
          >{inner}</a>
        ) : (
          <div class="p-5 rounded-2xl border border-dashed border-[var(--color-border)] bg-[var(--color-surface)] opacity-70">{inner}</div>
        );
      })}
    </div>
  </section>

  <!-- 샌드박스 쇼케이스 -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-20">
    <div class="flex items-baseline justify-between gap-3 mb-8 flex-wrap">
      <div class="flex items-baseline gap-3 flex-wrap">
        <h2 class="text-xl font-bold" style="font-family:'Space Grotesk','Pretendard',sans-serif">직접 만지는 샌드박스</h2>
        <span class="text-sm text-[var(--color-ink-300)] font-mono">배운 걸 자유롭게 실험하는 5개 공간</span>
      </div>
      <a href={`${base}sandbox/`} class="text-sm font-medium text-[var(--color-violet)] hover:underline whitespace-nowrap" style="font-family:'Space Grotesk','Pretendard',sans-serif">전체 보기 →</a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
      {sandboxes.map(s => (
        <a href={`${base}${s.path}`} class="group p-4 rounded-2xl border border-[var(--color-border)] bg-white hover:border-[var(--color-violet)] hover:shadow-lg transition-all">
          <div class="w-10 h-10 rounded-xl gradient-brand flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d={s.icon}/></svg>
          </div>
          <div class="font-bold text-sm text-[var(--color-ink-700)] group-hover:text-[var(--color-violet)] transition leading-tight" style="font-family:'Space Grotesk','Pretendard',sans-serif">{s.name}</div>
          <div class="text-[10px] font-mono text-[var(--color-ink-300)] mt-0.5">{s.hub}</div>
          <p class="text-xs text-[var(--color-ink-500)] mt-1 leading-snug">{s.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- 도구 쇼케이스 -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-20">
    <div class="flex items-baseline justify-between gap-3 mb-8 flex-wrap">
      <div class="flex items-baseline gap-3 flex-wrap">
        <h2 class="text-xl font-bold" style="font-family:'Space Grotesk','Pretendard',sans-serif">음악 연습 도구</h2>
        <span class="text-sm text-[var(--color-ink-300)] font-mono">설치 없이 바로 쓰는 무료 도구</span>
      </div>
      <a href={`${base}tools/`} class="text-sm font-medium text-[var(--color-violet)] hover:underline whitespace-nowrap" style="font-family:'Space Grotesk','Pretendard',sans-serif">전체 보기 →</a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
      {tools.map(t => (
        <a href={`${base}${t.path}`} class="group p-4 rounded-2xl border border-[var(--color-border)] bg-white hover:border-[var(--color-violet)] hover:shadow-lg transition-all">
          <div class="w-10 h-10 rounded-xl gradient-brand flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d={t.icon}/></svg>
          </div>
          <div class="font-bold text-sm text-[var(--color-ink-700)] group-hover:text-[var(--color-violet)] transition leading-tight" style="font-family:'Space Grotesk','Pretendard',sans-serif">{t.name}</div>
          <p class="text-xs text-[var(--color-ink-500)] mt-1 leading-snug">{t.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- 특징 섹션 -->
  <section class="border-t border-[var(--color-border)] bg-[var(--color-surface)]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
      <h2 class="text-xl font-bold text-center mb-10" style="font-family:'Space Grotesk','Pretendard',sans-serif">왜 SoundLab인가요?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {[
          {
            title: '즉각적인 피드백', desc: '슬라이더를 움직이면 파형과 스펙트럼이 실시간으로 반응합니다.',
            // 실시간 파형 (브랜드 로고 라인)
            icon: '<path d="M2 12h3l2-7 3 14 3-10 2 6h7" />',
          },
          {
            title: '개념 내장 학습', desc: '각 토픽마다 원리 설명과 "들어볼 것 / 볼 것" 가이드, 확인 퀴즈가 내장되어 있습니다.',
            // 펼친 책
            icon: '<path d="M12 6.5C10.5 5.5 8 5 4 5v12c4 0 6.5.5 8 1.5M12 6.5C13.5 5.5 16 5 20 5v12c-4 0-6.5.5-8 1.5M12 6.5v12" />',
          },
          {
            title: '설치 없이 즉시 시작', desc: '브라우저만 있으면 됩니다. 앱 설치, 회원가입 없이 링크 하나로 실습합니다.',
            // 번개
            icon: '<path d="M13 3 5 13h6l-1 8 8-10h-6l1-8z" />',
          },
        ].map(f => (
          <div class="group p-5 rounded-2xl bg-white border border-[var(--color-border)] hover:border-[var(--color-violet-light)] transition-colors">
            <div class="w-11 h-11 rounded-xl gradient-brand flex items-center justify-center mb-4 shadow-sm">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" set:html={f.icon} />
            </div>
            <h3 class="font-semibold mb-2" style="font-family:'Space Grotesk','Pretendard',sans-serif">{f.title}</h3>
            <p class="text-sm text-[var(--color-ink-500)] leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</Base>
