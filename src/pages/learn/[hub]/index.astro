---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import { HUB_META, HUBS } from '../../../content.config';

export async function getStaticPaths() {
  const all = (await getCollection('topics')).filter(t => !t.data.draft);
  // 토픽이 하나라도 있는 허브만 인덱스 페이지 생성
  const hubsWithTopics = HUBS.filter(h => all.some(t => t.data.hub === h));
  return hubsWithTopics.map(hub => ({
    params: { hub },
    props: {
      topics: all
        .filter(t => t.data.hub === hub)
        .sort((a, b) => a.data.order - b.data.order)
        .map(t => ({
          slug: t.id.split('/').slice(1).join('/'),
          ...t.data,
        })),
    },
  }));
}

const { hub } = Astro.params;
const { topics } = Astro.props;
const meta = HUB_META[hub as keyof typeof HUB_META];
const base = import.meta.env.BASE_URL;
---
<Base title={`${meta.kr} · ${meta.label}`} description={meta.desc}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">

    <nav class="flex items-center gap-2 text-xs font-mono text-[var(--color-ink-300)] mb-8">
      <a href={base} class="hover:text-[var(--color-violet)] transition">홈</a>
      <span>/</span>
      <a href={`${base}learn/`} class="hover:text-[var(--color-violet)] transition">지식 허브</a>
      <span>/</span>
      <span class="text-[var(--color-ink-700)]">{meta.kr}</span>
    </nav>

    <div class="mb-10">
      <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">{meta.label}</span>
      <h1 class="text-3xl sm:text-4xl font-bold mt-2 mb-2" style="font-family:'Space Grotesk'">{meta.kr}</h1>
      <p class="text-lg text-[var(--color-ink-500)]">{meta.desc}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {topics.map(t => (
        <a href={`${base}learn/${hub}/${t.slug}/`}
          class="group p-5 rounded-2xl border border-[var(--color-border)] bg-white hover:border-[var(--color-violet)] hover:-translate-y-0.5 transition-all">
          <div class="flex items-center gap-3 mb-2">
            <div class={`w-9 h-9 rounded-xl flex items-center justify-center text-sm font-mono font-bold text-white ${t.color === 'violet' ? 'gradient-brand' : ''}`}
              style={t.color === 'blue' ? 'background: linear-gradient(135deg,#2563eb,#7c3aed)' : ''}>
              {String(t.order).padStart(2, '0')}
            </div>
            <div>
              <span class="font-bold text-lg group-hover:gradient-brand-text transition" style="font-family:'Space Grotesk'">{t.title}</span>
              <span class="text-sm text-[var(--color-ink-300)] ml-1.5">{t.kr}</span>
            </div>
          </div>
          <p class="text-sm text-[var(--color-ink-500)] leading-relaxed">{t.desc}</p>
        </a>
      ))}
    </div>
  </div>
</Base>
