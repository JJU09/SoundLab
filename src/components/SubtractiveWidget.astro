---
// 감산합성 위젯 — 배음 풍부한 오실레이터를 필터로 깎아 음색 조형.
// AudioCore 위 osc → biquad filter → gain → core.input (지속음 드론, 실시간 카빙).
interface Props {
  config?: Record<string, any>;
}
const { config = {} } = Astro.props;
const c = { wave: config.wave ?? 'sawtooth', cutoff: config.cutoff ?? 2000, q: config.q ?? 4, type: config.type ?? 'lowpass' };
const waves: [OscillatorType, string][] = [['sawtooth','Saw'],['square','Square'],['triangle','Tri']];
const ftypes: [string, string][] = [['lowpass','Low Pass'],['highpass','High Pass'],['bandpass','Band Pass']];
const adv = (tier?: string) => (tier && tier !== 'easy' ? { 'data-adv': tier } : {});
const fHz = (v: number) => v >= 1000 ? (v / 1000).toFixed(1) + 'kHz' : Math.round(v) + 'Hz';
---
<div class="subtractive-widget rounded-2xl border border-[var(--color-border)] bg-white overflow-hidden"
  data-wave={c.wave} data-cutoff={c.cutoff} data-q={c.q} data-type={c.type}>

  <div class="flex items-center justify-between px-5 py-4 border-b border-[var(--color-border)] bg-[var(--color-surface)]">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg flex items-center justify-center gradient-brand">
        <svg class="text-white" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M3 7h6l3 10 3-14h6"/></svg>
      </div>
      <div>
        <span class="font-bold text-base" style="font-family:'Space Grotesk'">감산합성</span>
        <span class="text-sm text-[var(--color-ink-300)] ml-2">Subtractive</span>
      </div>
    </div>
    <button class="play-btn gradient-brand text-white text-sm font-semibold px-4 py-1.5 rounded-full transition hover:opacity-90" style="font-family:'Space Grotesk'">▶ 소리 켜기</button>
  </div>

  <div class="p-5 space-y-4">
    <!-- 신호 흐름 -->
    <div class="flex items-center gap-1.5 text-[10px] font-mono text-[var(--color-ink-300)]">
      <span class="px-2 py-1 rounded-md bg-[var(--color-surface-2)]">OSC</span>
      <span>→</span>
      <span class="px-2 py-1 rounded-md bg-[var(--color-violet-glow)] text-[var(--color-violet)]">FILTER</span>
      <span>→</span>
      <span class="px-2 py-1 rounded-md bg-[var(--color-surface-2)]">OUT</span>
      <span class="ml-1 text-[var(--color-ink-300)]">풍부한 배음을 깎아 음색을 만듭니다</span>
    </div>
    <!-- 파형 -->
    <div class="relative rounded-xl overflow-hidden bg-[var(--color-surface-2)] border border-[var(--color-border)]">
      <canvas class="scope-cv block w-full" style="height:90px"></canvas>
      <span class="absolute top-2 left-2.5 text-[10px] font-mono uppercase tracking-wider text-[var(--color-violet)] opacity-70">Waveform</span>
    </div>
    <!-- 스펙트럼 (normal) -->
    <div class="relative rounded-xl overflow-hidden bg-[var(--color-surface-2)] border border-[var(--color-border)]" {...adv('normal')}>
      <canvas class="spec-cv block w-full" style="height:90px"></canvas>
      <span class="absolute top-2 left-2.5 text-[10px] font-mono uppercase tracking-wider text-[var(--color-blue)] opacity-70">Spectrum · 배음이 깎이는 모습</span>
    </div>

    <!-- 오실레이터 파형 (easy) -->
    <div>
      <div class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)] mb-1.5">Oscillator · 음원 파형</div>
      <div class="flex gap-1 p-1 bg-[var(--color-surface-2)] rounded-xl w-fit" role="group">
        {waves.map(([v, t]) => (
          <button class="wave-btn px-3 py-1.5 rounded-lg text-xs font-semibold transition-all text-[var(--color-ink-500)]"
            data-wave={v} aria-pressed={v === c.wave ? 'true' : 'false'} style="font-family:'Space Grotesk'">{t}</button>
        ))}
      </div>
    </div>
    <!-- Cutoff (easy) -->
    <div>
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">Cutoff · 깎는 경계</span>
        <span class="cut-val text-sm font-mono text-[var(--color-ink-700)]">{fHz(c.cutoff)}</span>
      </div>
      <input type="range" class="sl-range cut-range" min="0" max="1000" step="1" value={Math.round(Math.sqrt(c.cutoff/18000)*1000)} aria-label="컷오프" />
    </div>
    <!-- Resonance (normal) -->
    <div {...adv('normal')}>
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">Resonance · 공진</span>
        <span class="q-val text-sm font-mono text-[var(--color-ink-700)]">{c.q.toFixed(1)}</span>
      </div>
      <input type="range" class="sl-range q-range" min="1" max="200" step="1" value={Math.round(c.q*10)} aria-label="공진" />
    </div>
    <!-- Filter Type (hard) -->
    <div {...adv('hard')}>
      <div class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)] mb-1.5">Filter Type · 필터 종류</div>
      <div class="flex gap-1.5 p-1 bg-[var(--color-surface-2)] rounded-xl w-fit ftype-group" role="group">
        {ftypes.map(([v, t]) => (
          <button class="ftype-btn px-3 py-1.5 rounded-lg text-xs font-mono transition-all text-[var(--color-ink-500)]"
            data-type={v} aria-pressed={v === c.type ? 'true' : 'false'}>{t}</button>
        ))}
      </div>
    </div>
  </div>
</div>

<script>
import { AudioCore } from '../audio/core';

function initSub(root: HTMLElement) {
  const core = new AudioCore();
  let wave = (root.dataset.wave as OscillatorType) || 'sawtooth';
  let cutoff = Number(root.dataset.cutoff) || 2000;
  let q = Number(root.dataset.q) || 4;
  let ftype = (root.dataset.type as BiquadFilterType) || 'lowpass';
  let playing = false;

  const filt = core.ctx.createBiquadFilter();
  filt.type = ftype; filt.frequency.value = cutoff; filt.Q.value = q;
  const amp = core.gain(0.35);
  filt.connect(amp); amp.connect(core.input);
  let osc: OscillatorNode | null = null;

  async function start() {
    await core.resume();
    osc = core.ctx.createOscillator(); osc.type = wave; osc.frequency.value = 165; osc.connect(filt); osc.start();
    playing = true;
  }
  function stop() { if (osc) { try { osc.stop(); } catch (e) {} osc.disconnect(); osc = null; } playing = false; }

  const scope = root.querySelector('.scope-cv') as HTMLCanvasElement;
  const spec = root.querySelector('.spec-cv') as HTMLCanvasElement;
  const fit = (cv: HTMLCanvasElement) => { const r = cv.getBoundingClientRect(); cv.width = Math.max(1, r.width * devicePixelRatio); cv.height = Math.max(1, r.height * devicePixelRatio); };
  fit(scope); fit(spec); addEventListener('resize', () => { fit(scope); fit(spec); });

  const td = new Uint8Array(core.analyser.fftSize);
  const fd = new Uint8Array(core.analyser.frequencyBinCount);
  function draw() {
    let ctx = scope.getContext('2d')!; let W = scope.width, H = scope.height;
    core.analyser.getByteTimeDomainData(td);
    ctx.clearRect(0, 0, W, H); ctx.beginPath();
    for (let i = 0; i < td.length; i++) { const x = (i / td.length) * W, y = (td[i] / 255) * H; i ? ctx.lineTo(x, y) : ctx.moveTo(x, y); }
    ctx.strokeStyle = '#7c3aed'; ctx.lineWidth = 1.6 * devicePixelRatio; ctx.stroke();
    ctx = spec.getContext('2d')!; W = spec.width; H = spec.height;
    core.analyser.getByteFrequencyData(fd);
    ctx.clearRect(0, 0, W, H);
    const bins = 96, bw = W / bins;
    for (let i = 0; i < bins; i++) { const v = fd[i] / 255; ctx.fillStyle = `rgba(37,99,235,${0.3 + v * 0.5})`; ctx.fillRect(i * bw, H - v * H, bw * 0.8, v * H); }
    requestAnimationFrame(draw);
  }
  draw();

  // 컨트롤
  const playBtn = root.querySelector('.play-btn') as HTMLButtonElement;
  playBtn.addEventListener('click', async () => {
    if (playing) { stop(); playBtn.textContent = '▶ 소리 켜기'; }
    else { await start(); playBtn.textContent = '⏸ 소리 끄기'; }
  });

  const setPct = (el: HTMLInputElement) => el.style.setProperty('--sl-pct', ((+el.value - +el.min) / (+el.max - +el.min) * 100) + '%');
  const fmtHz = (v: number) => v >= 1000 ? (v / 1000).toFixed(1) + 'kHz' : Math.round(v) + 'Hz';

  const cutR = root.querySelector('.cut-range') as HTMLInputElement, cutV = root.querySelector('.cut-val') as HTMLElement;
  setPct(cutR);
  cutR.addEventListener('input', () => {
    const x = +cutR.value / 1000; cutoff = Math.max(30, Math.round(x * x * 18000)); // 제곱 매핑(저역 해상도↑)
    cutV.textContent = fmtHz(cutoff); setPct(cutR); core.smooth(filt.frequency, cutoff);
  });

  const qR = root.querySelector('.q-range') as HTMLInputElement, qV = root.querySelector('.q-val') as HTMLElement;
  setPct(qR);
  qR.addEventListener('input', () => { q = +qR.value / 10; qV.textContent = q.toFixed(1); setPct(qR); core.smooth(filt.Q, q); });

  root.querySelectorAll<HTMLButtonElement>('.wave-btn').forEach(btn => {
    const sel = () => { btn.style.cssText = 'background:white;color:var(--color-violet);box-shadow:0 1px 4px rgba(0,0,0,0.08)'; };
    btn.addEventListener('click', () => {
      root.querySelectorAll('.wave-btn').forEach(b => { (b as HTMLElement).setAttribute('aria-pressed','false'); (b as HTMLElement).style.cssText = ''; });
      btn.setAttribute('aria-pressed','true'); sel(); wave = btn.dataset.wave as OscillatorType; if (osc) osc.type = wave;
    });
    if (btn.getAttribute('aria-pressed') === 'true') sel();
  });

  root.querySelectorAll<HTMLButtonElement>('.ftype-btn').forEach(btn => {
    const sel = () => { btn.style.cssText = 'background:white;color:var(--color-violet);box-shadow:0 1px 4px rgba(0,0,0,0.08)'; };
    btn.addEventListener('click', () => {
      root.querySelectorAll('.ftype-btn').forEach(b => { (b as HTMLElement).setAttribute('aria-pressed','false'); (b as HTMLElement).style.cssText = ''; });
      btn.setAttribute('aria-pressed','true'); sel(); ftype = btn.dataset.type as BiquadFilterType; filt.type = ftype;
    });
    if (btn.getAttribute('aria-pressed') === 'true') sel();
  });
}

document.querySelectorAll<HTMLElement>('.subtractive-widget').forEach(initSub);
</script>
