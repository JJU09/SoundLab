---
// 샘플레이트 위젯 — 시간축을 잘게 끊어 소리를 담는다. 비트뎁스(진폭축)의 짝.
// 연속 사인을 가상 SR로 영차홀드 샘플링 → 계단(재현)이 SR이 높을수록 원본에 밀착.
// 에일리어싱(실패)이 아니라 "재현 충실도 = samples/cycle"에 초점 (→ aliasing 토픽과 구분).
interface Props {
  config?: Record<string, any>;
}
const { config = {} } = Astro.props;
const c = { freq: config.freq ?? 200, sr: config.sr ?? 2000 };
const adv = (tier?: string) => (tier && tier !== 'easy' ? { 'data-adv': tier } : {});
---
<div class="sr-widget rounded-2xl border border-[var(--color-border)] bg-white overflow-hidden"
  data-freq={c.freq} data-sr={c.sr}>

  <div class="flex items-center justify-between px-5 py-4 border-b border-[var(--color-border)] bg-[var(--color-surface)]">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg flex items-center justify-center gradient-brand">
        <svg class="text-white" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M3 12h3v-4h3v8h3v-6h3v4h3"/></svg>
      </div>
      <div>
        <span class="font-bold text-base" style="font-family:'Space Grotesk','Pretendard',sans-serif">샘플레이트</span>
        <span class="text-sm text-[var(--color-ink-300)] ml-2">Sample Rate</span>
      </div>
    </div>
    <button class="play-btn gradient-brand text-white text-sm font-semibold px-4 py-1.5 rounded-full transition hover:opacity-90" style="font-family:'Space Grotesk','Pretendard',sans-serif">▶ 소리 켜기</button>
  </div>

  <div class="p-5 space-y-4">
    <!-- 샘플링 다이어그램 -->
    <div class="relative rounded-xl overflow-hidden bg-[var(--color-surface-2)] border border-[var(--color-border)]">
      <canvas class="diag-cv block w-full" style="height:140px"></canvas>
      <div class="absolute top-2 left-2.5 flex gap-3 text-[10px] font-mono">
        <span style="color:#a0a0c0">원본</span>
        <span style="color:#ef4444">샘플점</span>
        <span class="font-bold" style="color:#7c3aed">계단(재현)</span>
      </div>
    </div>
    <!-- 충실도 판정 -->
    <div class="sr-readout p-3 rounded-xl border text-sm font-mono"></div>
    <!-- 스펙트럼 (normal) -->
    <div class="relative rounded-xl overflow-hidden bg-[var(--color-surface-2)] border border-[var(--color-border)]" {...adv('normal')}>
      <canvas class="spec-cv block w-full" style="height:80px"></canvas>
      <span class="absolute top-2 left-2.5 text-[10px] font-mono uppercase tracking-wider text-[var(--color-blue)] opacity-70">Spectrum · 실제 들리는 음</span>
    </div>

    <!-- 샘플레이트 (easy — 핵심) -->
    <div>
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">Sample Rate · 1초당 샘플 수</span>
        <span class="sr-val text-sm font-mono text-[var(--color-ink-700)]">{c.sr}Hz</span>
      </div>
      <input type="range" class="sl-range sr-range" min="800" max="16000" step="50" value={c.sr} aria-label="샘플레이트" />
    </div>
    <!-- 신호 주파수 (normal) -->
    <div {...adv('normal')}>
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">Signal · 원본 주파수</span>
        <span class="freq-val text-sm font-mono text-[var(--color-ink-700)]">{c.freq}Hz</span>
      </div>
      <input type="range" class="sl-range freq-range" min="100" max="600" step="5" value={c.freq} aria-label="원본 주파수" />
    </div>
  </div>
</div>

<script>
import { AudioCore } from '../audio/core';

function initSR(root: HTMLElement) {
  const core = new AudioCore();
  let freq = Number(root.dataset.freq) || 200;
  let sr = Number(root.dataset.sr) || 2000; // 가상 샘플레이트
  let playing = false;
  let src: AudioBufferSourceNode | null = null;
  const out = core.gain(0.45); out.connect(core.input);
  const R = core.ctx.sampleRate; // 실제 출력 레이트

  // 영차홀드 버퍼 (가상 SR로 샘플링한 사인을 홀드, 1초 루프)
  function buildBuffer(): AudioBuffer {
    const buf = core.ctx.createBuffer(1, R, R);
    const d = buf.getChannelData(0);
    for (let n = 0; n < R; n++) {
      const vIndex = Math.floor(n * sr / R);
      d[n] = Math.sin(2 * Math.PI * freq * vIndex / sr);
    }
    return buf;
  }
  function restart() {
    if (!playing) return;
    if (src) { try { src.stop(); } catch (e) {} src.disconnect(); }
    src = core.ctx.createBufferSource(); src.buffer = buildBuffer(); src.loop = true; src.connect(out); src.start();
  }
  async function start() { await core.resume(); playing = true; restart(); }
  function stop() { if (src) { try { src.stop(); } catch (e) {} src.disconnect(); src = null; } playing = false; }

  const diag = root.querySelector('.diag-cv') as HTMLCanvasElement;
  const spec = root.querySelector('.spec-cv') as HTMLCanvasElement;
  const fit = (cv: HTMLCanvasElement) => { const r = cv.getBoundingClientRect(); cv.width = Math.max(1, r.width * devicePixelRatio); cv.height = Math.max(1, r.height * devicePixelRatio); };
  fit(diag); fit(spec); addEventListener('resize', () => { fit(diag); fit(spec); drawDiag(); });

  // 다이어그램: 약 2.5 주기 구간 — 원본 사인 + 샘플점 + 계단
  function drawDiag() {
    const ctx = diag.getContext('2d')!, W = diag.width, H = diag.height, mid = H / 2, amp = H * 0.36;
    const T = 2.5 / freq; // 2.5 주기(초)
    ctx.clearRect(0, 0, W, H);
    ctx.strokeStyle = 'rgba(160,160,192,0.2)'; ctx.lineWidth = devicePixelRatio; ctx.beginPath(); ctx.moveTo(0, mid); ctx.lineTo(W, mid); ctx.stroke();
    // 원본 연속 사인
    ctx.beginPath();
    for (let i = 0; i <= W; i++) { const t = (i / W) * T; const y = mid - Math.sin(2 * Math.PI * freq * t) * amp; i ? ctx.lineTo(i, y) : ctx.moveTo(i, y); }
    ctx.strokeStyle = '#a0a0c0'; ctx.lineWidth = 1.2 * devicePixelRatio; ctx.stroke();
    // 계단(영차홀드)
    ctx.beginPath();
    for (let i = 0; i <= W; i++) { const t = (i / W) * T; const vi = Math.floor(t * sr); const y = mid - Math.sin(2 * Math.PI * freq * vi / sr) * amp; i ? ctx.lineTo(i, y) : ctx.moveTo(i, y); }
    ctx.strokeStyle = '#7c3aed'; ctx.lineWidth = 2.2 * devicePixelRatio; ctx.stroke();
    // 샘플점
    const nS = Math.floor(T * sr);
    ctx.fillStyle = '#ef4444';
    for (let k = 0; k <= nS && k < 400; k++) { const t = k / sr; const x = (t / T) * W; const y = mid - Math.sin(2 * Math.PI * freq * k / sr) * amp; ctx.beginPath(); ctx.arc(x, y, 2.3 * devicePixelRatio, 0, 7); ctx.fill(); }
  }

  const fd = new Uint8Array(core.analyser.frequencyBinCount);
  function drawSpec() {
    const ctx = spec.getContext('2d')!, W = spec.width, H = spec.height;
    core.analyser.getByteFrequencyData(fd);
    ctx.clearRect(0, 0, W, H);
    const bins = 120, bw = W / bins;
    for (let i = 0; i < bins; i++) { const v = fd[i] / 255; ctx.fillStyle = `rgba(37,99,235,${0.3 + v * 0.5})`; ctx.fillRect(i * bw, H - v * H, bw * 0.8, v * H); }
    requestAnimationFrame(drawSpec);
  }
  drawSpec();

  const readout = root.querySelector('.sr-readout') as HTMLElement;
  function updateReadout() {
    const spc = sr / freq; // samples per cycle
    const nyq = sr / 2;
    let cls: string, msg: string;
    if (spc >= 16) { cls = 'border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-ink-500)]'; msg = `✓ 한 주기에 <b>${spc.toFixed(1)}개</b> 샘플 — 계단이 원본에 밀착, 매끄러운 재현`; }
    else if (spc >= 4) { cls = 'border-[#f59e0b] bg-[rgba(245,158,11,0.08)] text-[#b45309]'; msg = `△ 한 주기에 <b>${spc.toFixed(1)}개</b> 샘플 — 계단이 거칠어짐, 음색에 디지털 질감`; }
    else { cls = 'border-[#ef4444] bg-[rgba(239,68,68,0.07)] text-[#b91c1c]'; msg = `⚠ 한 주기에 <b>${spc.toFixed(1)}개</b>뿐 — 파형 형태가 무너짐 (나이퀴스트 ${nyq}Hz 근접 → 에일리어싱 위험)`; }
    readout.className = 'sr-readout p-3 rounded-xl border text-sm font-mono ' + cls;
    readout.innerHTML = msg;
  }

  function refreshVisual() { drawDiag(); updateReadout(); }
  refreshVisual();

  // 컨트롤
  const playBtn = root.querySelector('.play-btn') as HTMLButtonElement;
  playBtn.addEventListener('click', async () => {
    if (playing) { stop(); playBtn.textContent = '▶ 소리 켜기'; }
    else { await start(); playBtn.textContent = '⏸ 소리 끄기'; }
  });

  const setPct = (el: HTMLInputElement) => el.style.setProperty('--sl-pct', ((+el.value - +el.min) / (+el.max - +el.min) * 100) + '%');
  const srRange = root.querySelector('.sr-range') as HTMLInputElement, srVal = root.querySelector('.sr-val') as HTMLElement;
  const fRange = root.querySelector('.freq-range') as HTMLInputElement, fVal = root.querySelector('.freq-val') as HTMLElement;
  setPct(srRange); setPct(fRange);
  // input = 시각 즉시 / change = 오디오 재생성(크래클 방지)
  srRange.addEventListener('input', () => { sr = +srRange.value; srVal.textContent = sr + 'Hz'; setPct(srRange); refreshVisual(); });
  fRange.addEventListener('input', () => { freq = +fRange.value; fVal.textContent = freq + 'Hz'; setPct(fRange); refreshVisual(); });
  srRange.addEventListener('change', restart);
  fRange.addEventListener('change', restart);
}

document.querySelectorAll<HTMLElement>('.sr-widget').forEach(initSR);
</script>
