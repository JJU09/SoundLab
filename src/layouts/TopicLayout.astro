---
import Base from './Base.astro';
import TopicWidget from '../components/TopicWidget.astro';
import Quiz from '../components/Quiz.astro';
import ScaffoldBar from '../components/ScaffoldBar.astro';
import AdUnit from '../components/AdUnit.astro';
import { HUB_META, SANDBOX_OF } from '../content.config';
import { QUIZZES } from '../lib/quizzes';

interface TopicData {
  hub: keyof typeof HUB_META;
  title: string;
  kr: string;
  order: number;
  color: 'violet' | 'blue';
  tagline: string;
  desc: string;
  widget: string;
  widgetConfig?: Record<string, any>;
  quiz?: string;
  scaffold?: boolean;
}
interface NavLink { slug: string; title: string; kr: string; }

interface Props {
  data: TopicData;
  prev?: NavLink | null;
  next?: NavLink | null;
}
const { data, prev, next } = Astro.props;
const base = import.meta.env.BASE_URL;
const hub = HUB_META[data.hub];
const sandbox = SANDBOX_OF[data.hub]; // 허브 샌드박스 크로스링크 (학습→자유 실험 동선)
const hasWidget = data.widget && data.widget !== 'none';
const quiz = data.quiz ? QUIZZES[data.quiz] : null;
const num = String(data.order).padStart(2, '0');
const accent = data.color === 'violet'
  ? 'border-[var(--color-violet-light)] text-[var(--color-violet)] bg-[var(--color-violet-glow)]'
  : 'border-[var(--color-blue-light)] text-[var(--color-blue)] bg-[var(--color-blue-glow)]';
---
<Base title={`${data.title} (${data.kr})`} description={data.desc} type="article"
  breadcrumbs={[
    { name: '홈', url: base },
    { name: hub.kr, url: `${base}learn/${data.hub}/` },
    { name: data.title, url: Astro.url.pathname },
  ]}>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">

    <!-- 브레드크럼 -->
    <nav class="flex items-center gap-2 text-xs font-mono text-[var(--color-ink-300)] mb-8">
      <a href={base} class="hover:text-[var(--color-violet)] transition">홈</a>
      <span>/</span>
      <a href={`${base}learn/${data.hub}/`} class="hover:text-[var(--color-violet)] transition">{hub.kr}</a>
      <span>/</span>
      <span class="text-[var(--color-ink-700)]">{data.title}</span>
    </nav>

    <div {...(data.scaffold ? { 'data-scaffold': '', 'data-level': 'normal' } : {})}>
    {data.scaffold && (
      // 페인트 전 저장된 난이도를 미리 적용해 normal 깜빡임(FOUC) 제거. 기본값은 normal 유지.
      <script is:inline>
        (function () {
          try {
            var L = localStorage.getItem('sl-level');
            if (L === 'easy' || L === 'hard') document.currentScript.parentElement.setAttribute('data-level', L);
          } catch (e) {}
        })();
      </script>
    )}
    {data.scaffold && <ScaffoldBar />}
    <div class={`grid grid-cols-1 gap-10 ${hasWidget ? 'lg:grid-cols-[1fr_380px]' : ''}`}>

      <!-- 왼쪽: 개념 설명 -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <span class={`text-xs font-mono px-2.5 py-1 rounded-full border ${accent}`}>
            {hub.label.toUpperCase()} · {num}
          </span>
        </div>

        <h1 class="text-3xl sm:text-4xl font-bold mb-2 leading-tight" style="font-family:'Space Grotesk','Pretendard',sans-serif">
          {data.title}
          <span class="text-[var(--color-ink-300)] font-medium text-2xl ml-2">{data.kr}</span>
        </h1>
        <p class={`text-lg font-medium mb-6 ${data.color === 'violet' ? 'gradient-brand-text' : ''}`}
          style={data.color === 'blue' ? 'color:var(--color-blue)' : ''}>
          {data.tagline}
        </p>

        <p class="text-[var(--color-ink-700)] leading-relaxed mb-8">{data.desc}</p>

        <!-- MDX 본문 -->
        <div class="topic-body space-y-6 text-sm leading-relaxed text-[var(--color-ink-700)]">
          <slot />
        </div>

        <!-- 객관식 퀴즈 -->
        {quiz && <Quiz questions={quiz} color={data.color} />}

        <!-- 샌드박스 크로스링크 — 배운 개념을 자유롭게 실험 -->
        {sandbox && (
          <a href={`${base}${sandbox.path}`}
            class="group flex items-center gap-4 mt-10 p-5 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-violet)] hover:shadow-lg transition-all">
            <div class="w-11 h-11 flex-none rounded-xl gradient-brand flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M5 3v18M5 12h14M19 3v18M9 7h.01M15 17h.01"/></svg>
            </div>
            <div class="min-w-0 flex-1">
              <div class="text-[10px] font-mono uppercase tracking-wider text-[var(--color-violet)]">Sandbox · 직접 실험</div>
              <div class="font-bold text-[var(--color-ink-700)] group-hover:text-[var(--color-violet)] transition" style="font-family:'Space Grotesk','Pretendard',sans-serif">{sandbox.name}에서 자유롭게 실험해보기</div>
              <p class="text-sm text-[var(--color-ink-500)] mt-0.5">{hub.kr} 허브의 요소를 직접 조합하며 소리를 만들어 보세요.</p>
            </div>
            <svg class="w-5 h-5 flex-none text-[var(--color-ink-300)] group-hover:text-[var(--color-violet)] group-hover:translate-x-0.5 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        )}

        <!-- 이전/다음 -->
        <div class="flex items-center justify-between mt-12 pt-8 border-t border-[var(--color-border)]">
          {prev ? (
            <a href={`${base}learn/${data.hub}/${prev.slug}/`}
              class="flex items-center gap-2 text-sm font-medium text-[var(--color-ink-500)] hover:text-[var(--color-violet)] transition group">
              <svg class="w-4 h-4 transition group-hover:-translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
              <div>
                <div class="text-[10px] font-mono uppercase tracking-wider text-[var(--color-ink-300)]">이전</div>
                <div>{prev.title} ({prev.kr})</div>
              </div>
            </a>
          ) : <div />}

          {next ? (
            <a href={`${base}learn/${data.hub}/${next.slug}/`}
              class="flex items-center gap-2 text-sm font-medium text-[var(--color-ink-500)] hover:text-[var(--color-violet)] transition group text-right">
              <div>
                <div class="text-[10px] font-mono uppercase tracking-wider text-[var(--color-ink-300)]">다음</div>
                <div>{next.title} ({next.kr})</div>
              </div>
              <svg class="w-4 h-4 transition group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          ) : <div />}
        </div>
      </div>

      <!-- 오른쪽: 인터랙티브 위젯 -->
      {hasWidget && (
        <div class="lg:sticky lg:top-20 self-start">
          <TopicWidget widget={data.widget} config={data.widgetConfig} />
        </div>
      )}

    </div>
    </div>

    <AdUnit />
  </div>
</Base>
