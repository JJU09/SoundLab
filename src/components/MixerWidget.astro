---
// 믹서 위젯 — 3트랙(드럼/베이스/멜로디) 채널스트립. 믹싱 허브 전 토픽 공용.
// widgetConfig로 변주: controls(노출 컨트롤), tracks(초기 게인/팬 — "망가진 믹스"로 시작하는 과제형).
//   controls: ['fader']            → balance 토픽 (M/S는 normal 티어부터)
//   controls: ['fader','pan']      → pan 토픽
//   controls: ['fader','eq']       → eq-masking 토픽
//   controls: ['fader','comp']     → compressor 토픽 (마스터 컴프 패널)
//   controls: ['fader','send']     → depth 토픽 (트랙별 리버브 센드)
interface Props {
  config?: Record<string, any>;
}
const { config = {} } = Astro.props;
const controls: string[] = config.controls ?? ['fader'];
const showPan = controls.includes('pan');
const showEq = controls.includes('eq');
const showComp = controls.includes('comp');
const showSend = controls.includes('send');

const TRACKS = [
  { id: 'drums', name: 'Drums', kr: '드럼', color: '#7c3aed' },
  { id: 'bass', name: 'Bass', kr: '베이스', color: '#2563eb' },
  { id: 'lead', name: 'Melody', kr: '멜로디', color: '#f59e0b' },
];
const trackCfg = (id: string) => config.tracks?.[id] ?? {};
const initVol = (id: string): number => trackCfg(id).vol ?? 70;
const initPan = (id: string): number => trackCfg(id).pan ?? 0;
const initSend = (id: string): number => trackCfg(id).send ?? 0;

const adv = (tier?: string) => (tier && tier !== 'easy' ? { 'data-adv': tier } : {});
---
<div class="mixer-widget rounded-2xl border border-[var(--color-border)] bg-white overflow-hidden" data-show-pan={showPan ? '1' : ''} data-show-eq={showEq ? '1' : ''} data-show-comp={showComp ? '1' : ''} data-show-send={showSend ? '1' : ''}>

  <div class="flex items-center justify-between px-5 py-4 border-b border-[var(--color-border)] bg-[var(--color-surface)]">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg flex items-center justify-center gradient-brand">
        <svg class="text-white" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24"><path d="M4 21v-7M4 10V3M12 21v-9M12 8V3M20 21v-5M20 12V3M1 14h6M9 8h6M17 16h6"/></svg>
      </div>
      <div>
        <span class="font-bold text-base" style="font-family:'Space Grotesk'">믹서</span>
        <span class="text-sm text-[var(--color-ink-300)] ml-2">3-Track Mixer</span>
      </div>
    </div>
    <button class="play-btn gradient-brand text-white text-sm font-semibold px-4 py-1.5 rounded-full transition hover:opacity-90" style="font-family:'Space Grotesk'">▶ 소리 켜기</button>
  </div>

  <div class="p-5 space-y-4">
    <!-- 신호 흐름 -->
    <div class="flex items-center gap-1.5 text-[10px] font-mono text-[var(--color-ink-300)] flex-wrap">
      <span class="px-2 py-1 rounded-md bg-[var(--color-surface-2)]">3 TRACKS</span>
      <span>→</span>
      <span class="px-2 py-1 rounded-md bg-[var(--color-violet-glow)] text-[var(--color-violet)]">FADER{showEq ? ' · EQ' : ''}{showPan ? ' · PAN' : ''}{showSend ? ' · SEND' : ''}</span>
      <span>→</span>
      <span class="px-2 py-1 rounded-md bg-[var(--color-surface-2)]">MASTER{showComp ? ' · COMP' : ''}{showSend ? ' ← VERB' : ''}</span>
      <span class="ml-1">세 악기가 한 스피커에서 만납니다 — 자리를 잡아주세요</span>
    </div>

    {/* 트랙 스펙트럼 오버레이 (eq 토픽) — 마스킹을 눈으로 확인 */}
    {showEq && (
      <div class="relative rounded-xl overflow-hidden bg-[var(--color-surface-2)] border border-[var(--color-border)]">
        <canvas class="ovl-spec block w-full" style="height:130px"></canvas>
        <span class="absolute top-2 left-2.5 text-[10px] font-mono uppercase tracking-wider text-[var(--color-ink-300)]">Spectrum · 트랙별 겹침</span>
        <span class="absolute top-2 right-2.5 flex items-center gap-2 text-[9px] font-mono">
          {TRACKS.map(t => (
            <span class="flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full" style={`background:${t.color}`}></span><span class="text-[var(--color-ink-300)]">{t.name}</span></span>
          ))}
        </span>
      </div>
    )}

    <!-- 채널 스트립 -->
    <div class="space-y-3">
      {TRACKS.map(t => (
        <div class="track-strip rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-3" data-track={t.id} data-vol={initVol(t.id)} data-pan={initPan(t.id)} data-send={initSend(t.id)}>
          <div class="flex items-center gap-3 flex-wrap">
            <div class="flex items-center gap-2 w-24 flex-none">
              <span class="w-2 h-2 rounded-full flex-none" style={`background:${t.color}`}></span>
              <span class="min-w-0">
                <span class="block text-xs font-bold text-[var(--color-ink-700)] leading-tight" style="font-family:'Space Grotesk'">{t.name}</span>
                <span class="block text-[10px] text-[var(--color-ink-300)] leading-tight">{t.kr}</span>
              </span>
            </div>
            <!-- 트랙 미터 -->
            <div class="w-16 flex-none h-1.5 rounded-full bg-[var(--color-surface-2)] border border-[var(--color-border)] overflow-hidden">
              <div class="trk-meter h-full w-0 rounded-full" style={`background:${t.color}`}></div>
            </div>
            <!-- 페이더 -->
            <div class="flex items-center gap-2 flex-1 min-w-[140px]">
              <input type="range" class="sl-range trk-fader flex-1" min="0" max="100" step="1" value={initVol(t.id)} aria-label={`${t.kr} 볼륨`} />
              <span class="trk-vol text-[11px] font-mono text-[var(--color-ink-700)] w-9 text-right">{initVol(t.id)}%</span>
              <span class="trk-db text-[10px] font-mono text-[var(--color-ink-300)] w-14 text-right" {...adv('normal')}>—</span>
            </div>
            <!-- Pan (pan 토픽에서만) -->
            {showPan && (
              <div class="flex items-center gap-1.5 flex-none">
                <span class="text-[10px] font-mono text-[var(--color-ink-300)]">L</span>
                <input type="range" class="sl-range trk-pan w-20" min="-50" max="50" step="1" value={initPan(t.id) * 50} aria-label={`${t.kr} 팬`} />
                <span class="text-[10px] font-mono text-[var(--color-ink-300)]">R</span>
                <span class="trk-pan-val text-[10px] font-mono text-[var(--color-ink-700)] w-7 text-right">C</span>
              </div>
            )}
            <!-- Reverb Send (depth 토픽에서만) -->
            {showSend && (
              <div class="flex items-center gap-1.5 flex-none">
                <span class="text-[10px] font-mono text-[var(--color-ink-300)]">SEND</span>
                <input type="range" class="sl-range trk-send w-20" min="0" max="100" step="1" value={initSend(t.id)} aria-label={`${t.kr} 리버브 센드`} />
                <span class="trk-send-val text-[10px] font-mono text-[var(--color-ink-700)] w-8 text-right">{initSend(t.id)}%</span>
              </div>
            )}
            <!-- Mute / Solo (normal↑) -->
            <div class="flex items-center gap-1 flex-none" {...adv('normal')}>
              <button class="trk-mute w-7 h-7 rounded-lg border border-[var(--color-border)] text-[10px] font-mono font-bold text-[var(--color-ink-300)] transition" aria-pressed="false" title="뮤트">M</button>
              <button class="trk-solo w-7 h-7 rounded-lg border border-[var(--color-border)] text-[10px] font-mono font-bold text-[var(--color-ink-300)] transition" aria-pressed="false" title="솔로">S</button>
            </div>
          </div>
          {showEq && (
            <div class="flex items-center gap-3 flex-wrap mt-2.5 pt-2.5 border-t border-[var(--color-border)]">
              <span class="text-[10px] font-mono uppercase tracking-wider text-[var(--color-ink-300)] w-24 flex-none">EQ · 1밴드</span>
              <div class="flex items-center gap-2 flex-none" {...adv('normal')}>
                <span class="text-[10px] font-mono text-[var(--color-ink-300)]">FREQ</span>
                <input type="range" class="sl-range eq-freq w-24" min="0" max="1000" step="1" value="368" aria-label={`${t.kr} EQ 주파수`} />
                <span class="eq-freq-val text-[10px] font-mono text-[var(--color-ink-700)] w-12">500Hz</span>
              </div>
              <div class="flex items-center gap-2 flex-1 min-w-[140px]">
                <span class="text-[10px] font-mono text-[var(--color-ink-300)]">GAIN</span>
                <input type="range" class="sl-range eq-gain flex-1" min="-12" max="12" step="0.5" value="0" aria-label={`${t.kr} EQ 게인`} />
                <span class="eq-gain-val text-[10px] font-mono text-[var(--color-ink-700)] w-14 text-right">0.0 dB</span>
              </div>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- 마스터 미터 -->
    <div class="flex items-center gap-2 pt-1">
      <span class="text-[10px] font-mono uppercase tracking-wider text-[var(--color-ink-300)] w-24 flex-none">Master · 합</span>
      <div class="flex-1 h-2.5 rounded-full bg-[var(--color-surface-2)] border border-[var(--color-border)] overflow-hidden">
        <div class="mst-meter h-full w-0 rounded-full"
          style="background:linear-gradient(90deg,#7c3aed 0%,#7c3aed 60%,#f59e0b 80%,#ef4444 100%)"></div>
      </div>
      <span class="mst-val text-[11px] font-mono text-[var(--color-ink-300)] w-10 text-right">—</span>
    </div>

    {/* 마스터 컴프레서 (compressor 토픽) */}
    {showComp && (
      <div class="comp-panel rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-3 space-y-2.5">
        <div class="flex items-center justify-between">
          <span class="text-[10px] font-mono uppercase tracking-wider text-[var(--color-violet)]">Compressor · 마스터 다이내믹스</span>
          <span class="text-[10px] font-mono text-[var(--color-ink-300)]" {...adv('normal')}>4:1 · soft knee</span>
        </div>

        {/* 게인 리덕션 미터 (오른쪽→왼쪽으로 차오름) */}
        <div class="flex items-center gap-2">
          <span class="text-[10px] font-mono uppercase tracking-wider text-[var(--color-ink-300)] w-24 flex-none">GR · 리덕션</span>
          <div class="flex-1 h-2.5 rounded-full bg-[var(--color-surface-2)] border border-[var(--color-border)] overflow-hidden flex justify-end">
            <div class="gr-meter h-full w-0 rounded-full" style="background:linear-gradient(270deg,#ef4444 0%,#f59e0b 60%,#7c3aed 100%)"></div>
          </div>
          <span class="gr-val text-[11px] font-mono text-[var(--color-ink-300)] w-14 text-right">0.0 dB</span>
        </div>

        {/* THRESHOLD — 전 티어 (easy의 단일 손잡이) */}
        <div class="flex items-center gap-2">
          <span class="text-[10px] font-mono text-[var(--color-ink-300)] w-24 flex-none">THRESHOLD</span>
          <input type="range" class="sl-range comp-thresh flex-1" min="-40" max="0" step="0.5" value="0" aria-label="컴프레서 임계점" />
          <span class="comp-thresh-val text-[10px] font-mono text-[var(--color-ink-700)] w-14 text-right">0.0 dB</span>
        </div>

        {/* RATIO + MAKEUP — normal↑ */}
        <div class="flex items-center gap-2" {...adv('normal')}>
          <span class="text-[10px] font-mono text-[var(--color-ink-300)] w-24 flex-none">RATIO</span>
          <input type="range" class="sl-range comp-ratio flex-1" min="1" max="12" step="0.5" value="4" aria-label="컴프레서 비율" />
          <span class="comp-ratio-val text-[10px] font-mono text-[var(--color-ink-700)] w-14 text-right">4.0:1</span>
        </div>
        <div class="flex items-center gap-2" {...adv('normal')}>
          <span class="text-[10px] font-mono text-[var(--color-ink-300)] w-24 flex-none">MAKEUP</span>
          <input type="range" class="sl-range comp-makeup flex-1" min="0" max="12" step="0.5" value="0" aria-label="메이크업 게인" />
          <span class="comp-makeup-val text-[10px] font-mono text-[var(--color-ink-700)] w-14 text-right">+0.0 dB</span>
        </div>

        {/* ATTACK + RELEASE — hard */}
        <div class="flex items-center gap-2" {...adv('hard')}>
          <span class="text-[10px] font-mono text-[var(--color-ink-300)] w-24 flex-none">ATTACK</span>
          <input type="range" class="sl-range comp-attack flex-1" min="0" max="100" step="1" value="3" aria-label="어택" />
          <span class="comp-attack-val text-[10px] font-mono text-[var(--color-ink-700)] w-14 text-right">3 ms</span>
        </div>
        <div class="flex items-center gap-2" {...adv('hard')}>
          <span class="text-[10px] font-mono text-[var(--color-ink-300)] w-24 flex-none">RELEASE</span>
          <input type="range" class="sl-range comp-release flex-1" min="10" max="500" step="5" value="250" aria-label="릴리즈" />
          <span class="comp-release-val text-[10px] font-mono text-[var(--color-ink-700)] w-14 text-right">250 ms</span>
        </div>
      </div>
    )}

    {/* L/R 스테레오 미터 (pan 토픽) */}
    {showPan && (
      <div class="space-y-1">
        {['L', 'R'].map(ch => (
          <div class="flex items-center gap-2">
            <span class="text-[10px] font-mono uppercase tracking-wider text-[var(--color-ink-300)] w-24 flex-none text-right pr-1">{ch}</span>
            <div class="flex-1 h-1.5 rounded-full bg-[var(--color-surface-2)] border border-[var(--color-border)] overflow-hidden">
              <div class={`lr-meter-${ch.toLowerCase()} h-full w-0 rounded-full bg-[var(--color-blue)]`}></div>
            </div>
            <span class="w-10 flex-none"></span>
          </div>
        ))}
      </div>
    )}
  </div>
</div>

<script>
import { AudioCore } from '../audio/core';
import { MixBus } from '../audio/mixer';

function initMixer(root: HTMLElement) {
  const core = new AudioCore();
  const bus = new MixBus(core);
  bus.buildStandard();

  // 리버브 센드 버스 (depth 토픽) — 초기 센드 적용 전에 활성화해야 sends 맵이 준비됨
  const useSend = root.dataset.showSend === '1';
  if (useSend) bus.enableReverb();

  // 초기 상태 적용 (과제형 "망가진 믹스" 포함)
  root.querySelectorAll<HTMLElement>('.track-strip').forEach(strip => {
    const id = strip.dataset.track!;
    bus.setVol(id, Number(strip.dataset.vol) || 70);
    bus.setPan(id, Number(strip.dataset.pan) || 0);
    if (useSend) bus.setSend(id, (Number(strip.dataset.send) || 0) / 100);
  });

  const setPct = (el: HTMLInputElement) => el.style.setProperty('--sl-pct', ((+el.value - +el.min) / (+el.max - +el.min) * 100) + '%');
  const toDb = (pct: number) => pct <= 0 ? '-∞ dB' : (20 * Math.log10(pct / 100)).toFixed(1) + ' dB';

  // 채널 스트립 바인딩
  root.querySelectorAll<HTMLElement>('.track-strip').forEach(strip => {
    const id = strip.dataset.track!;
    const fader = strip.querySelector('.trk-fader') as HTMLInputElement;
    const volEl = strip.querySelector('.trk-vol') as HTMLElement;
    const dbEl = strip.querySelector('.trk-db') as HTMLElement;
    setPct(fader);
    dbEl.textContent = toDb(+fader.value);
    fader.addEventListener('input', () => {
      const v = +fader.value;
      setPct(fader);
      volEl.textContent = v + '%';
      dbEl.textContent = toDb(v);
      bus.setVol(id, v);
    });

    const panR = strip.querySelector('.trk-pan') as HTMLInputElement | null;
    if (panR) {
      const panVal = strip.querySelector('.trk-pan-val') as HTMLElement;
      const showPan = (v: number) => panVal.textContent = v === 0 ? 'C' : (v < 0 ? 'L' : 'R') + Math.abs(v * 2);
      setPct(panR);
      showPan(+panR.value);
      panR.addEventListener('input', () => {
        setPct(panR);
        showPan(+panR.value);
        bus.setPan(id, +panR.value / 50);
      });
    }

    const sendR = strip.querySelector('.trk-send') as HTMLInputElement | null;
    if (sendR) {
      const sendVal = strip.querySelector('.trk-send-val') as HTMLElement;
      setPct(sendR);
      sendR.addEventListener('input', () => {
        const v = +sendR.value;
        setPct(sendR);
        sendVal.textContent = v + '%';
        bus.setSend(id, v / 100);
      });
    }

    // EQ (eq 토픽에서만 렌더)
    const eqFreq = strip.querySelector('.eq-freq') as HTMLInputElement | null;
    const eqGain = strip.querySelector('.eq-gain') as HTMLInputElement | null;
    if (eqFreq && eqGain) {
      const freqVal = strip.querySelector('.eq-freq-val') as HTMLElement;
      const gainVal = strip.querySelector('.eq-gain-val') as HTMLElement;
      const toHz = (p: number) => Math.round(100 * Math.pow(80, p)); // log 100Hz–8kHz
      const fmtHz = (v: number) => v >= 1000 ? (v / 1000).toFixed(1) + 'kHz' : v + 'Hz';
      setPct(eqFreq); setPct(eqGain);
      eqFreq.addEventListener('input', () => {
        const hz = toHz(+eqFreq.value / 1000);
        setPct(eqFreq);
        freqVal.textContent = fmtHz(hz);
        bus.setEqFreq(id, hz);
      });
      eqGain.addEventListener('input', () => {
        const db = +eqGain.value;
        setPct(eqGain);
        gainVal.textContent = (db > 0 ? '+' : '') + db.toFixed(1) + ' dB';
        bus.setEqGain(id, db);
      });
    }

    const muteBtn = strip.querySelector('.trk-mute') as HTMLButtonElement;
    const soloBtn = strip.querySelector('.trk-solo') as HTMLButtonElement;
    muteBtn.addEventListener('click', () => {
      const on = muteBtn.getAttribute('aria-pressed') !== 'true';
      muteBtn.setAttribute('aria-pressed', String(on));
      muteBtn.style.cssText = on ? 'background:#ef4444;color:white;border-color:#ef4444' : '';
      bus.setMute(id, on);
    });
    soloBtn.addEventListener('click', () => {
      const on = soloBtn.getAttribute('aria-pressed') !== 'true';
      soloBtn.setAttribute('aria-pressed', String(on));
      soloBtn.style.cssText = on ? 'background:#f59e0b;color:white;border-color:#f59e0b' : '';
      bus.setSolo(id, on);
    });
  });

  // 마스터 컴프레서 (compressor 토픽)
  const compPanel = root.querySelector('.comp-panel') as HTMLElement | null;
  if (compPanel) {
    bus.enableCompressor();
    const bind = (sel: string, fmt: (v: number) => string, apply: (v: number) => void) => {
      const sl = compPanel.querySelector(sel) as HTMLInputElement | null;
      if (!sl) return;
      const out = compPanel.querySelector(sel + '-val') as HTMLElement;
      setPct(sl);
      sl.addEventListener('input', () => {
        const v = +sl.value;
        setPct(sl);
        out.textContent = fmt(v);
        apply(v);
      });
    };
    bind('.comp-thresh', v => v.toFixed(1) + ' dB', v => bus.setCompThreshold(v));
    bind('.comp-ratio', v => v.toFixed(1) + ':1', v => bus.setCompRatio(v));
    bind('.comp-makeup', v => '+' + v.toFixed(1) + ' dB', v => bus.setCompMakeup(v));
    bind('.comp-attack', v => v + ' ms', v => bus.setCompAttack(v / 1000));
    bind('.comp-release', v => v + ' ms', v => bus.setCompRelease(v / 1000));
  }
  const grMeter = root.querySelector('.gr-meter') as HTMLElement | null;
  const grVal = root.querySelector('.gr-val') as HTMLElement | null;

  // 재생
  const playBtn = root.querySelector('.play-btn') as HTMLButtonElement;
  playBtn.addEventListener('click', async () => {
    if (bus.playing) {
      bus.stop();
      playBtn.textContent = '▶ 소리 켜기';
    } else {
      await bus.start();
      playBtn.textContent = '⏸ 소리 끄기';
    }
  });

  // 미터 루프
  const meters = [...root.querySelectorAll<HTMLElement>('.track-strip')].map(strip => ({
    id: strip.dataset.track!,
    bar: strip.querySelector('.trk-meter') as HTMLElement,
  }));
  const mstBar = root.querySelector('.mst-meter') as HTMLElement;
  const mstVal = root.querySelector('.mst-val') as HTMLElement;
  const lrL = root.querySelector('.lr-meter-l') as HTMLElement | null;
  const lrR = root.querySelector('.lr-meter-r') as HTMLElement | null;
  if (lrL) bus.enableStereoMeter();

  // 트랙 스펙트럼 오버레이 (eq 토픽)
  const TRACK_COLORS: Record<string, string> = { drums: '124,58,237', bass: '37,99,235', lead: '245,158,11' };
  const ovl = root.querySelector('.ovl-spec') as HTMLCanvasElement | null;
  let ovlCtx: CanvasRenderingContext2D | null = null;
  if (ovl) {
    ovlCtx = ovl.getContext('2d');
    const fit = () => { const r = ovl.getBoundingClientRect(); ovl.width = Math.max(1, r.width * devicePixelRatio); ovl.height = Math.max(1, r.height * devicePixelRatio); };
    fit(); addEventListener('resize', fit);
  }
  function drawOverlay() {
    if (!ovl || !ovlCtx) return;
    const W = ovl.width, H = ovl.height, ctx = ovlCtx;
    ctx.clearRect(0, 0, W, H);
    if (!bus.playing) return;
    const bars = 56;
    for (const id of ['drums', 'bass', 'lead']) {
      const fd = bus.getTrackSpectrum(id);
      if (!fd) continue;
      const N = fd.length, rgb = TRACK_COLORS[id];
      ctx.beginPath();
      ctx.moveTo(0, H);
      for (let i = 0; i < bars; i++) {
        // 제곱 매핑으로 저역 해상도 확보 (sandbox drawSpec과 동일 컨벤션)
        const f0 = Math.pow(i / bars, 2), f1 = Math.pow((i + 1) / bars, 2);
        const lo = Math.floor(f0 * N), hi = Math.max(lo + 1, Math.floor(f1 * N));
        let mx = 0; for (let j = lo; j < hi && j < N; j++) mx = Math.max(mx, fd[j]);
        const x = (i + 0.5) / bars * W, y = H - (mx / 255) * (H - 8 * devicePixelRatio);
        ctx.lineTo(x, y);
      }
      ctx.lineTo(W, H);
      ctx.closePath();
      ctx.fillStyle = `rgba(${rgb},0.28)`;
      ctx.fill();
      ctx.strokeStyle = `rgba(${rgb},0.85)`;
      ctx.lineWidth = 1.4 * devicePixelRatio;
      ctx.stroke();
    }
  }
  function drawMeters() {
    requestAnimationFrame(drawMeters);
    drawOverlay();
    if (!bus.playing) {
      meters.forEach(m => m.bar.style.width = '0%');
      mstBar.style.width = '0%'; mstVal.textContent = '—';
      if (lrL && lrR) { lrL.style.width = '0%'; lrR.style.width = '0%'; }
      if (grMeter && grVal) { grMeter.style.width = '0%'; grVal.textContent = '0.0 dB'; }
      return;
    }
    if (grMeter && grVal) {
      const gr = bus.getGainReduction(); // 0 또는 음수 dB
      grMeter.style.width = Math.min(100, (-gr / 20) * 100) + '%'; // 20dB 풀스케일
      grVal.textContent = gr.toFixed(1) + ' dB';
    }
    if (lrL && lrR) {
      const [l, r] = bus.getStereoLevels();
      lrL.style.width = Math.min(100, l * 130) + '%';
      lrR.style.width = Math.min(100, r * 130) + '%';
    }
    for (const m of meters) m.bar.style.width = Math.min(100, bus.getLevel(m.id) * 130) + '%';
    const d = core.getScope();
    let peak = 0;
    for (let i = 0; i < d.length; i++) { const v = Math.abs(d[i] - 128) / 128; if (v > peak) peak = v; }
    const pct = Math.min(100, peak * 130);
    mstBar.style.width = pct + '%';
    mstVal.textContent = peak > 0.98 ? 'CLIP' : Math.round(pct) + '%';
  }
  drawMeters();
}

document.querySelectorAll<HTMLElement>('.mixer-widget').forEach(initMixer);
</script>
