---
import Base from '../../layouts/Base.astro';
const base = import.meta.env.BASE_URL;
const desc = '20Hz~20kHz 임의 주파수를 재생하는 무료 온라인 톤 제너레이터(주파수 발생기). 가청주파수·청력 테스트, 스피커 점검, 이명 주파수 찾기에. 설치 없이 브라우저에서.';
---
<Base title="톤 제너레이터 · 청력 테스트" description={desc} type="website"
  breadcrumbs={[{ name: '홈', url: base }, { name: '도구', url: `${base}tools/` }, { name: '톤 제너레이터', url: Astro.url.pathname }]}>

<div class="max-w-xl mx-auto px-4 sm:px-6 py-12">
  <nav class="flex items-center gap-2 text-xs font-mono text-[var(--color-ink-300)] mb-6">
    <a href={base} class="hover:text-[var(--color-violet)] transition">홈</a><span>/</span>
    <a href={`${base}tools/`} class="hover:text-[var(--color-violet)] transition">도구</a><span>/</span>
    <span class="text-[var(--color-ink-700)]">톤 제너레이터</span>
  </nav>

  <div class="mb-6">
    <span class="text-xs font-mono px-2.5 py-1 rounded-full border border-[var(--color-violet-light)] text-[var(--color-violet)] bg-[var(--color-violet-glow)]">TOOLS</span>
    <h1 class="text-3xl font-bold mt-3 mb-2" style="font-family:'Space Grotesk','Pretendard',sans-serif">톤 제너레이터 · 청력 테스트</h1>
    <p class="text-[var(--color-ink-500)]">원하는 주파수의 순음을 재생합니다. 가청주파수·청력 테스트, 스피커 점검에. 볼륨을 낮게 시작하세요.</p>
  </div>

  <div class="tonegen rounded-2xl border border-[var(--color-border)] bg-white overflow-hidden">
    <div class="p-6 sm:p-8 space-y-6">
      <!-- 주파수 표시 + 재생 -->
      <div class="text-center">
        <div class="freq-display text-6xl font-bold leading-none tabular-nums" style="font-family:'Space Grotesk'">440<span class="text-2xl text-[var(--color-ink-300)] ml-1">Hz</span></div>
        <div class="hear-hint text-xs font-mono text-[var(--color-ink-300)] mt-2 h-4"></div>
      </div>

      <button class="play-btn w-full gradient-brand text-white font-semibold py-4 rounded-xl text-lg flex items-center justify-center gap-2 transition hover:opacity-90" style="font-family:'Space Grotesk','Pretendard',sans-serif">
        <span class="play-dot w-2.5 h-2.5 rounded-full bg-white"></span><span class="play-label">▶ 재생</span>
      </button>

      <!-- 주파수 슬라이더 + 입력 -->
      <div>
        <div class="flex items-center justify-between mb-1">
          <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">Frequency · 주파수</span>
          <span class="flex items-center gap-1">
            <input type="number" class="freq-input w-20 text-right text-sm font-mono px-2 py-0.5 rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-ink-700)]" min="20" max="20000" step="1" value="440" aria-label="주파수 직접 입력" />
            <span class="text-xs font-mono text-[var(--color-ink-300)]">Hz</span>
          </span>
        </div>
        <input type="range" class="sl-range freq-range w-full" min="0" max="1000" step="1" value="478" aria-label="주파수" />
        <div class="flex justify-between text-[10px] font-mono text-[var(--color-ink-300)] mt-1 px-0.5">
          <span>20Hz</span><span>200</span><span>2k</span><span>20kHz</span>
        </div>
      </div>

      <!-- 파형 + 볼륨 -->
      <div class="grid grid-cols-2 gap-4">
        <div>
          <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)] block mb-1.5">Waveform</span>
          <div class="wave-tabs flex gap-1 p-1 bg-[var(--color-surface-2)] rounded-xl" role="group" aria-label="파형">
            {[['sine','∿'],['square','⊓'],['sawtooth','◺'],['triangle','△']].map(([w,sym]) => (
              <button class="wave-btn flex-1 py-1.5 rounded-lg text-sm text-[var(--color-ink-500)] transition" data-wave={w} aria-pressed={w==='sine'?'true':'false'} title={w}>{sym}</button>
            ))}
          </div>
        </div>
        <div>
          <div class="flex items-center justify-between mb-1.5">
            <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">Volume</span>
            <span class="vol-val text-sm font-mono text-[var(--color-ink-700)]">25%</span>
          </div>
          <input type="range" class="sl-range vol-range w-full" min="0" max="100" step="1" value="25" aria-label="볼륨" />
        </div>
      </div>

      <!-- 청력 테스트: 빠른 주파수 -->
      <div class="pt-2 border-t border-[var(--color-border)]">
        <div class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)] mb-2">청력 테스트 · 주파수 점프</div>
        <div class="flex flex-wrap gap-1.5">
          {[60,125,250,500,1000,2000,4000,8000,10000,12000,14000,15000,16000,17000,18000,19000,20000].map(f => (
            <button class="hz-chip text-xs font-mono px-2.5 py-1.5 rounded-lg border border-[var(--color-border)] text-[var(--color-ink-500)] hover:border-[var(--color-violet)] hover:text-[var(--color-violet)] transition" data-hz={f}>
              {f >= 1000 ? (f/1000) + 'k' : f}
            </button>
          ))}
        </div>
        <p class="text-[10px] font-mono text-[var(--color-ink-300)] mt-2">고음부터 내려오며 들리는 한계를 찾아보세요. 성인은 보통 15~17kHz, 젊을수록 더 높이.</p>
      </div>
    </div>
  </div>

  <p class="text-xs text-[var(--color-ink-300)] mt-4 text-center">⚠ 볼륨을 낮게 시작하세요. 고주파를 큰 소리로 오래 들으면 청력에 해로울 수 있습니다. 헤드폰 권장.</p>

  <div class="mt-8 p-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] text-sm text-[var(--color-ink-500)]">
    주파수가 음높이를 어떻게 결정하는지는 <a href={`${base}glossary/hz/`} class="text-[var(--color-violet)] font-medium hover:underline">헤르츠</a>와
    <a href={`${base}learn/acoustics/tone/`} class="text-[var(--color-violet)] font-medium hover:underline">소리의 3요소</a>에서.
  </div>
</div>

<script>
import { AudioCore } from '../../audio/core';

function initToneGen(root: HTMLElement) {
  const core = new AudioCore();
  let freq = 440, wave: OscillatorType = 'sine', vol = 25, playing = false;
  const VOL_CAP = 0.4; // 고주파 순음 안전 상한
  const out = core.gain(0); out.connect(core.input);
  let osc: OscillatorNode | null = null;

  // 슬라이더 0..1000 ↔ 로그 20..20000Hz
  const posToHz = (p: number) => Math.round(20 * Math.pow(1000, p / 1000));
  const hzToPos = (hz: number) => Math.log(hz / 20) / Math.log(1000) * 1000;
  const fmtHz = (hz: number) => hz >= 1000 ? (hz / 1000).toFixed(hz % 1000 === 0 ? 0 : 1) + 'kHz' : hz + 'Hz';

  const $ = <T extends HTMLElement>(s: string) => root.querySelector(s) as T;
  const display = $('.freq-display'), hint = $('.hear-hint');
  const range = $<HTMLInputElement>('.freq-range'), input = $<HTMLInputElement>('.freq-input');
  const setPct = (el: HTMLInputElement) => el.style.setProperty('--sl-pct', ((+el.value - +el.min) / (+el.max - +el.min) * 100) + '%');

  function renderFreq() {
    display.innerHTML = (freq >= 1000 ? (freq / 1000).toFixed(freq % 1000 === 0 ? 0 : 2) : freq) +
      '<span class="text-2xl text-[var(--color-ink-300)] ml-1">' + (freq >= 1000 ? 'kHz' : 'Hz') + '</span>';
    hint.textContent = freq >= 17000 ? '이게 들리면 청력이 아주 좋은 편이에요'
      : freq >= 15000 ? '15kHz 이상 — 들리면 양호'
      : freq <= 40 ? '초저음 — 스피커·이어폰에선 안 들릴 수 있어요' : '';
  }
  function applyFreq() { if (osc) core.smooth(osc.frequency, freq, 0.01); }

  function setFreq(hz: number, fromInput?: boolean) {
    freq = Math.max(20, Math.min(20000, Math.round(hz)));
    if (!fromInput) input.value = String(freq);
    range.value = String(hzToPos(freq)); setPct(range);
    renderFreq(); applyFreq();
  }

  async function start() {
    await core.resume();
    osc = core.ctx.createOscillator(); osc.type = wave; osc.frequency.value = freq;
    osc.connect(out); osc.start();
    core.smooth(out.gain, vol / 100 * VOL_CAP, 0.02); // 클릭 방지 페이드인
    playing = true;
  }
  function stop() {
    core.smooth(out.gain, 0, 0.02);
    const o = osc; osc = null; playing = false;
    if (o) setTimeout(() => { try { o.stop(); o.disconnect(); } catch (e) {} }, 60);
  }

  // 컨트롤
  const playBtn = $('.play-btn'), playDot = $('.play-dot'), playLabel = $('.play-label');
  async function setPlaying(on: boolean) {
    if (on === playing) return;
    if (on) { await start(); playBtn.style.cssText = 'background:var(--color-surface-2);color:var(--color-ink-700)'; playDot.style.cssText = 'background:#ef4444;box-shadow:0 0 8px #ef4444'; playLabel.textContent = '■ 정지'; }
    else { stop(); playBtn.style.cssText = ''; playDot.style.cssText = 'background:white'; playLabel.textContent = '▶ 재생'; }
  }
  playBtn.addEventListener('click', () => setPlaying(!playing));

  setPct(range);
  range.addEventListener('input', () => { setFreq(posToHz(+range.value)); });
  input.addEventListener('input', () => { const v = +input.value; if (v >= 20 && v <= 20000) setFreq(v, true); });

  const volRange = $<HTMLInputElement>('.vol-range'), volVal = $('.vol-val');
  setPct(volRange);
  volRange.addEventListener('input', () => { vol = +volRange.value; volVal.textContent = vol + '%'; setPct(volRange); if (playing) core.smooth(out.gain, vol / 100 * VOL_CAP, 0.02); });

  const waveBtns = [...root.querySelectorAll<HTMLElement>('.wave-btn')];
  waveBtns.forEach(b => {
    const on = () => b.style.cssText = 'background:white;color:var(--color-violet);box-shadow:0 1px 4px rgba(0,0,0,0.08)';
    b.addEventListener('click', () => {
      waveBtns.forEach(x => { x.setAttribute('aria-pressed', 'false'); x.style.cssText = ''; });
      b.setAttribute('aria-pressed', 'true'); on();
      wave = b.dataset.wave as OscillatorType; if (osc) osc.type = wave;
    });
    if (b.getAttribute('aria-pressed') === 'true') on();
  });

  // 청력 테스트 칩 — 클릭 시 그 주파수로 점프 + 재생
  root.querySelectorAll<HTMLElement>('.hz-chip').forEach(c => {
    c.addEventListener('click', async () => { setFreq(Number(c.dataset.hz)); if (!playing) await setPlaying(true); });
  });

  setFreq(440);
}

document.querySelectorAll<HTMLElement>('.tonegen').forEach(initToneGen);
</script>

</Base>
