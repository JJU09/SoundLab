---
// 수준별 학습 제어 바 — 유저 심리 버튼으로 Easy/Normal/Hard 전환.
// 부모 [data-scaffold] 컨테이너의 data-level을 바꾸고 'soundlab:level' 이벤트 발행.
---
<div class="scaffold-bar flex items-center justify-between gap-2 mb-8 p-1.5 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)]">
  <button type="button" class="sb-down flex items-center gap-1.5 px-3 py-2 rounded-xl text-xs font-semibold text-[var(--color-ink-500)] hover:bg-white hover:text-[var(--color-violet)] transition" style="font-family:'Space Grotesk'"></button>
  <span class="sb-label flex items-center gap-1.5 text-xs font-mono"></span>
  <button type="button" class="sb-up flex items-center gap-1.5 px-3 py-2 rounded-xl text-xs font-semibold text-[var(--color-ink-500)] hover:bg-white hover:text-[var(--color-violet)] transition" style="font-family:'Space Grotesk'"></button>
</div>

<script>
const LEVELS = ['easy', 'normal', 'hard'] as const;
type Level = typeof LEVELS[number];

const TEXT: Record<Level, { label: string; dot: string; down?: string; up?: string }> = {
  easy:   { label: 'Easy · 초급', dot: '#22c55e', up: '이제 좀 이해가 돼요 (중급으로) →' },
  normal: { label: 'Normal · 중급', dot: '#7c3aed', down: '← 내용이 너무 어려워요', up: '내용이 좀 쉬워요 →' },
  hard:   { label: 'Hard · 고급', dot: '#ef4444', down: '← 갑자기 너무 어려워졌어요 (중급으로)' },
};

function initBar(bar: HTMLElement) {
  const root = bar.closest('[data-scaffold]') as HTMLElement;
  if (!root) return;
  const down = bar.querySelector('.sb-down') as HTMLButtonElement;
  const up = bar.querySelector('.sb-up') as HTMLButtonElement;
  const label = bar.querySelector('.sb-label') as HTMLElement;

  const saved = (localStorage.getItem('sl-level') as Level) || 'normal';
  let level: Level = LEVELS.includes(saved) ? saved : 'normal';

  function render() {
    const t = TEXT[level];
    root.dataset.level = level;
    label.innerHTML = `<span style="width:7px;height:7px;border-radius:50%;background:${t.dot};display:inline-block"></span>${t.label}`;
    down.textContent = t.down || '';
    down.style.visibility = t.down ? 'visible' : 'hidden';
    up.textContent = t.up || '';
    up.style.visibility = t.up ? 'visible' : 'hidden';
    root.dispatchEvent(new CustomEvent('soundlab:level', { detail: level, bubbles: true }));
  }

  function go(dir: number) {
    const i = LEVELS.indexOf(level);
    const ni = Math.min(LEVELS.length - 1, Math.max(0, i + dir));
    if (ni === i) return;
    level = LEVELS[ni];
    localStorage.setItem('sl-level', level);
    render();
  }

  down.addEventListener('click', () => go(-1));
  up.addEventListener('click', () => go(1));
  render();
}

document.querySelectorAll<HTMLElement>('.scaffold-bar').forEach(initBar);
</script>
