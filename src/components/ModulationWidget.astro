---
// LFO·모듈레이션 위젯 — 느린 LFO 하나를 여러 목적지에 라우팅해 트레몰로·비브라토·와우를 만든다.
//   carrier(saw) → filter(lp) → amp → core.input
//   lfo(sine, rate) → lfoGain(depth) → [target AudioParam]  (pitch / volume / filter 중 하나)
// 핵심 학습: 같은 LFO라도 "어디에 연결하느냐"가 효과를 결정. widgetConfig: rate, depth, target.
interface Props {
  config?: Record<string, any>;
}
const { config = {} } = Astro.props;
const rate = config.rate ?? 5;       // Hz
const depth = config.depth ?? 50;    // %
const target = config.target ?? 'volume';
const targets: [string, string][] = [['pitch', '피치 · 비브라토'], ['volume', '음량 · 트레몰로'], ['filter', '필터 · 와우']];
const shapes: [OscillatorType, string][] = [['sine', 'Sine'], ['triangle', 'Tri'], ['square', 'Square']];
const adv = (tier?: string) => (tier && tier !== 'easy' ? { 'data-adv': tier } : {});
---
<div class="mod-widget rounded-2xl border border-[var(--color-border)] bg-white overflow-hidden"
  data-rate={rate} data-depth={depth} data-target={target}>

  <div class="flex items-center justify-between px-5 py-4 border-b border-[var(--color-border)] bg-[var(--color-surface)]">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg flex items-center justify-center gradient-brand">
        <svg class="text-white" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c2-6 4 6 6 0s4-6 6 0 4 6 6 0"/></svg>
      </div>
      <div>
        <span class="font-bold text-base" style="font-family:'Space Grotesk','Pretendard',sans-serif">LFO 모듈레이션</span>
        <span class="text-sm text-[var(--color-ink-300)] ml-2">Modulation</span>
      </div>
    </div>
    <button class="play-btn gradient-brand text-white text-sm font-semibold px-4 py-1.5 rounded-full transition hover:opacity-90" style="font-family:'Space Grotesk','Pretendard',sans-serif">▶ 소리 켜기</button>
  </div>

  <div class="p-5 space-y-4">
    <!-- 라이브 스코프 -->
    <div class="relative rounded-xl overflow-hidden bg-[var(--color-surface-2)] border border-[var(--color-border)]">
      <canvas class="scope-cv block w-full" style="height:120px"></canvas>
      <span class="absolute top-2 left-2.5 text-[10px] font-mono uppercase tracking-wider text-[var(--color-violet)] opacity-70">Output · 변조된 소리</span>
    </div>

    <!-- 변조 목적지 (전 티어 — 이 토픽의 핵심) -->
    <div>
      <div class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)] mb-1.5">Destination · LFO를 어디에 연결?</div>
      <div class="flex gap-1 p-1 bg-[var(--color-surface-2)] rounded-xl" role="group">
        {targets.map(([v, t]) => (
          <button class="tgt-btn flex-1 px-2 py-1.5 rounded-lg text-xs font-semibold transition-all text-[var(--color-ink-500)]"
            data-target={v} aria-pressed={v === target ? 'true' : 'false'} style="font-family:'Space Grotesk','Pretendard',sans-serif">{t}</button>
        ))}
      </div>
    </div>

    <!-- Rate -->
    <div>
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">Rate · 흔드는 속도</span>
        <span class="rate-val text-sm font-mono text-[var(--color-ink-700)]">{rate}Hz</span>
      </div>
      <input type="range" class="sl-range rate-range" min="0.2" max="20" step="0.1" value={rate} aria-label="LFO 속도" />
    </div>
    <!-- Depth -->
    <div>
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">Depth · 흔드는 깊이</span>
        <span class="depth-val text-sm font-mono text-[var(--color-ink-700)]">{depth}%</span>
      </div>
      <input type="range" class="sl-range depth-range" min="0" max="100" step="1" value={depth} aria-label="LFO 깊이" />
    </div>

    <!-- LFO 파형 (normal↑) -->
    <div {...adv('normal')}>
      <div class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)] mb-1.5">LFO Shape · 변조 파형</div>
      <div class="flex gap-1 p-1 bg-[var(--color-surface-2)] rounded-xl" role="group">
        {shapes.map(([v, t]) => (
          <button class="shape-btn flex-1 px-3 py-1.5 rounded-lg text-xs font-semibold transition-all text-[var(--color-ink-500)]"
            data-shape={v} aria-pressed={v === 'sine' ? 'true' : 'false'} style="font-family:'Space Grotesk','Pretendard',sans-serif">{t}</button>
        ))}
      </div>
    </div>
  </div>
</div>

<script>
import { AudioCore } from '../audio/core';

function initMod(root: HTMLElement) {
  const core = new AudioCore();
  let rate = Number(root.dataset.rate) || 5;
  let depth = Number(root.dataset.depth) || 50;
  let target = root.dataset.target || 'volume';
  let shape: OscillatorType = 'sine';
  let playing = false;

  // 고정 신호 경로 (목적지에 무관하게 항상 존재)
  const FC = 220, AMP_BASE = 0.32, CUT_BASE = 1200;
  const filter = core.ctx.createBiquadFilter(); filter.type = 'lowpass'; filter.frequency.value = CUT_BASE; filter.Q.value = 5;
  const amp = core.gain(AMP_BASE);
  filter.connect(amp); amp.connect(core.input);

  // 목적지별 깊이 스케일 — depth%(0..1) → 변조량
  const scale = (t: string) => {
    if (t === 'pitch') return depth / 100 * 30;        // ±Hz (≈±2반음 @220)
    if (t === 'volume') return depth / 100 * AMP_BASE; // ±gain (100%면 0..2배 스윙)
    return depth / 100 * 1000;                          // filter ±Hz
  };
  const paramOf = (t: string): AudioParam =>
    t === 'pitch' ? carrier!.frequency : t === 'volume' ? amp.gain : filter.frequency;

  let carrier: OscillatorNode | null = null;
  let lfo: OscillatorNode | null = null;
  let lfoGain: GainNode | null = null;

  function applyRouting() {
    if (!lfoGain || !carrier) return;
    try { lfoGain.disconnect(); } catch (e) {}
    // 이전 목적지의 base 값 복원 (연결 해제 시 자동 복귀하지만 명시적으로)
    carrier.frequency.value = FC; amp.gain.value = AMP_BASE; filter.frequency.value = CUT_BASE;
    lfoGain.gain.value = scale(target);
    lfoGain.connect(paramOf(target));
  }

  async function start() {
    await core.resume();
    carrier = core.ctx.createOscillator(); carrier.type = 'sawtooth'; carrier.frequency.value = FC;
    carrier.connect(filter);
    lfo = core.ctx.createOscillator(); lfo.type = shape; lfo.frequency.value = rate;
    lfoGain = core.gain(scale(target));
    lfo.connect(lfoGain);
    carrier.start(); lfo.start();
    applyRouting();
    playing = true;
  }
  function stop() {
    [carrier, lfo].forEach(o => { if (o) { try { o.stop(); } catch (e) {} o.disconnect(); } });
    if (lfoGain) { try { lfoGain.disconnect(); } catch (e) {} }
    carrier = lfo = null; lfoGain = null;
    // base 복원
    amp.gain.value = AMP_BASE; filter.frequency.value = CUT_BASE;
    playing = false;
  }

  // ── 스코프 ──
  const scope = root.querySelector('.scope-cv') as HTMLCanvasElement;
  const fit = () => { const r = scope.getBoundingClientRect(); scope.width = Math.max(1, r.width * devicePixelRatio); scope.height = Math.max(1, r.height * devicePixelRatio); };
  fit(); addEventListener('resize', fit);
  const td = new Uint8Array(core.analyser.fftSize);
  function draw() {
    requestAnimationFrame(draw);
    const ctx = scope.getContext('2d')!, W = scope.width, H = scope.height;
    core.analyser.getByteTimeDomainData(td);
    ctx.clearRect(0, 0, W, H); ctx.beginPath();
    for (let i = 0; i < td.length; i++) { const x = (i / td.length) * W, y = (td[i] / 255) * H; i ? ctx.lineTo(x, y) : ctx.moveTo(x, y); }
    ctx.strokeStyle = '#7c3aed'; ctx.lineWidth = 1.6 * devicePixelRatio; ctx.stroke();
  }
  draw();

  // ── 컨트롤 ──
  const setPct = (el: HTMLInputElement) => el.style.setProperty('--sl-pct', ((+el.value - +el.min) / (+el.max - +el.min) * 100) + '%');

  const playBtn = root.querySelector('.play-btn') as HTMLButtonElement;
  playBtn.addEventListener('click', async () => {
    if (playing) { stop(); playBtn.textContent = '▶ 소리 켜기'; }
    else { await start(); playBtn.textContent = '⏸ 소리 끄기'; }
  });

  // 목적지 버튼
  root.querySelectorAll<HTMLButtonElement>('.tgt-btn').forEach(btn => {
    const sel = () => { btn.style.cssText = 'background:white;color:var(--color-violet);box-shadow:0 1px 4px rgba(0,0,0,0.08)'; };
    btn.addEventListener('click', () => {
      root.querySelectorAll('.tgt-btn').forEach(b => { (b as HTMLElement).setAttribute('aria-pressed', 'false'); (b as HTMLElement).style.cssText = ''; });
      btn.setAttribute('aria-pressed', 'true'); sel();
      target = btn.dataset.target!;
      applyRouting();
    });
    if (btn.getAttribute('aria-pressed') === 'true') sel();
  });

  // LFO 파형 버튼
  root.querySelectorAll<HTMLButtonElement>('.shape-btn').forEach(btn => {
    const sel = () => { btn.style.cssText = 'background:white;color:var(--color-violet);box-shadow:0 1px 4px rgba(0,0,0,0.08)'; };
    btn.addEventListener('click', () => {
      root.querySelectorAll('.shape-btn').forEach(b => { (b as HTMLElement).setAttribute('aria-pressed', 'false'); (b as HTMLElement).style.cssText = ''; });
      btn.setAttribute('aria-pressed', 'true'); sel();
      shape = btn.dataset.shape as OscillatorType; if (lfo) lfo.type = shape;
    });
    if (btn.getAttribute('aria-pressed') === 'true') sel();
  });

  // Rate / Depth
  const rateRange = root.querySelector('.rate-range') as HTMLInputElement;
  const rateVal = root.querySelector('.rate-val') as HTMLElement;
  setPct(rateRange);
  rateRange.addEventListener('input', () => {
    rate = +rateRange.value; rateVal.textContent = rate + 'Hz'; setPct(rateRange);
    if (lfo) core.smooth(lfo.frequency, rate);
  });

  const depthRange = root.querySelector('.depth-range') as HTMLInputElement;
  const depthVal = root.querySelector('.depth-val') as HTMLElement;
  setPct(depthRange);
  depthRange.addEventListener('input', () => {
    depth = +depthRange.value; depthVal.textContent = depth + '%'; setPct(depthRange);
    if (lfoGain) core.smooth(lfoGain.gain, scale(target));
  });
}

document.querySelectorAll<HTMLElement>('.mod-widget').forEach(initMod);
</script>
