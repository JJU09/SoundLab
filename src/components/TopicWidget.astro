---
// 토픽 프런트매터의 widget/widgetConfig → 실제 인터랙티브 컴포넌트로 리졸브.
// 새 위젯(synth/phase/aliasing)은 여기 분기만 추가하면 됨.
import EffectPlayer from './EffectPlayer.astro';
import SynthPlayer from './SynthPlayer.astro';
import SubtractiveWidget from './SubtractiveWidget.astro';
import AdditiveWidget from './AdditiveWidget.astro';
import FmWidget from './FmWidget.astro';
import PhaseWidget from './PhaseWidget.astro';
import ToneWidget from './ToneWidget.astro';
import CombWidget from './CombWidget.astro';
import BitcrushWidget from './BitcrushWidget.astro';
import AliasWidget from './AliasWidget.astro';
import MixerWidget from './MixerWidget.astro';
import { MODULE_MAP, type ModuleId } from '../lib/modules';

interface Props {
  widget: string;
  config?: Record<string, any>;
}
const { widget, config = {} } = Astro.props;

const moduleId = config.moduleId as ModuleId | undefined;
const effectModule = widget === 'effect' && moduleId ? MODULE_MAP[moduleId] : null;
---
{effectModule && <EffectPlayer module={effectModule} />}
{widget === 'synth' && <SynthPlayer config={config} />}
{widget === 'subtractive' && <SubtractiveWidget config={config} />}
{widget === 'additive' && <AdditiveWidget config={config} />}
{widget === 'fm' && <FmWidget config={config} />}
{widget === 'phase' && <PhaseWidget config={config} />}
{widget === 'tone' && <ToneWidget config={config} />}
{widget === 'comb' && <CombWidget config={config} />}
{widget === 'bitcrush' && <BitcrushWidget config={config} />}
{widget === 'aliasing' && <AliasWidget config={config} />}
{widget === 'mixer' && <MixerWidget config={config} />}
