---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { HUB_META, HUBS, SANDBOX_OF } from '../content.config';
import { ADSENSE_ID } from '../ads.config';

interface Props {
  title: string;
  description?: string;
  image?: string;   // og:image 경로(base 기준). 미지정 시 기본 OG 이미지.
  type?: string;    // og:type — 기본 website, 글/레슨은 article
  breadcrumbs?: { name: string; url: string }[]; // BreadcrumbList JSON-LD용 (url은 사이트 절대경로)
}
const SITE_NAME = 'SoundLab';
// GA4 측정 ID(G-XXXXXXX). 비워두면 분석 스크립트 미출력(자리만 확보). 발급 후 채우면 자동 활성.
const GA_ID = 'G-XE8CLT7CER';
// 피드백 폼(노션) URL. 비워두면 헤더 피드백 버튼 미노출. 노션 폼 공유 링크를 붙여넣으면 자동 활성.
const FEEDBACK_URL = 'https://outgoing-crayfish-491.notion.site/38285182bf2b804b97dbe266e0f9b9e7?pvs=105';
const { title, description = 'Web Audio API로 듣고 만지며 배우는 인터랙티브 사운드·음악 학습 사이트', image, type = 'website', breadcrumbs } = Astro.props;
const base = import.meta.env.BASE_URL;
const fullTitle = `${title} · ${SITE_NAME}`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image ?? `${base}og.png`, Astro.site).href;
const siteUrl = new URL(base, Astro.site).href;

// 내비 드롭다운 데이터 — 허브별 콘텐츠/샌드박스 보유 여부
const topics = (await getCollection('topics')).filter(t => !t.data.draft);
const hubsSorted = [...HUBS].sort((a, b) => HUB_META[a].order - HUB_META[b].order);
const hubNav = hubsSorted.map(h => ({
  id: h, kr: HUB_META[h].kr, label: HUB_META[h].label,
  ready: topics.some(t => t.data.hub === h),
  href: `${base}learn/${h}/`,
}));
const sandboxNav = hubsSorted.map(h => ({
  id: h, kr: HUB_META[h].kr, label: HUB_META[h].label,
  href: SANDBOX_OF[h] ? `${base}${SANDBOX_OF[h]!.path}` : undefined,
  ready: !!SANDBOX_OF[h],
}));
---
<!doctype html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="sitemap" href={`${base}sitemap-index.xml`} />

  <!-- Open Graph / 트위터 카드 (SNS·카카오 공유 미리보기) -->
  <meta property="og:site_name" content={SITE_NAME} />
  <meta property="og:type" content={type} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="ko_KR" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- 구조화 데이터 -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE_NAME,
    url: siteUrl,
    inLanguage: 'ko',
    description,
  })} />

  {breadcrumbs && breadcrumbs.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((b, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: b.name,
        item: new URL(b.url, Astro.site).href,
      })),
    })} />
  )}

  {GA_ID && <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>}
  {GA_ID && <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${GA_ID}',{anonymize_ip:true});`} />}

  {/* Google AdSense — ads.config.ts 의 ADSENSE_ID 설정 시 자동 활성화 */}
  {ADSENSE_ID && <meta name="google-adsense-account" content={ADSENSE_ID} />}
  {ADSENSE_ID && <script is:inline async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_ID}`} crossorigin="anonymous"></script>}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" />
</head>
<body class="min-h-screen">
  <!-- 배경 그리드 패턴 -->
  <div class="fixed inset-0 -z-10 pointer-events-none"
    style="background-image: linear-gradient(var(--color-border) 1px, transparent 1px), linear-gradient(90deg, var(--color-border) 1px, transparent 1px); background-size: 40px 40px; opacity: 0.5;">
  </div>

  <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-[var(--color-border)]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between gap-4">
      <a href={base} class="flex items-center gap-2.5 group">
        <div class="w-7 h-7 rounded-lg gradient-brand flex items-center justify-center flex-none">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
            <path d="M2 12h3l2-7 3 14 3-10 2 6h7"/>
          </svg>
        </div>
        <span class="font-bold text-[15px] tracking-tight gradient-brand-text" style="font-family:'Space Grotesk','Pretendard',sans-serif">SoundLab</span>
      </a>

      <nav class="hidden sm:flex items-center gap-1">
        <!-- 지식 허브 드롭다운 -->
        <div class="nav-dd relative">
          <a href={`${base}learn/`} class="nav-link inline-flex items-center gap-1">
            지식 허브
            <svg class="nav-chev w-3 h-3 transition-transform" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6"/></svg>
          </a>
          <div class="nav-panel">
            {hubNav.map(h => h.ready ? (
              <a href={h.href} class="nav-item group">
                <span class="text-[10px] font-mono text-[var(--color-ink-300)] w-20 group-hover:text-[var(--color-violet)]">{h.label}</span>
                <span class="font-medium">{h.kr}</span>
              </a>
            ) : (
              <div class="nav-item nav-item-off">
                <span class="text-[10px] font-mono w-20">{h.label}</span>
                <span class="font-medium">{h.kr}</span>
                <span class="ml-auto text-[9px] font-mono px-1.5 py-0.5 rounded-full bg-[var(--color-surface-2)]">준비 중</span>
              </div>
            ))}
          </div>
        </div>

        <!-- 샌드박스 드롭다운 -->
        <div class="nav-dd relative">
          <a href={`${base}sandbox/`} class="nav-link inline-flex items-center gap-1">
            샌드박스
            <svg class="nav-chev w-3 h-3 transition-transform" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6"/></svg>
          </a>
          <div class="nav-panel">
            {sandboxNav.map(s => s.ready ? (
              <a href={s.href} class="nav-item group">
                <span class="text-[10px] font-mono text-[var(--color-ink-300)] w-20 group-hover:text-[var(--color-violet)]">{s.label}</span>
                <span class="font-medium">{s.kr}</span>
              </a>
            ) : (
              <div class="nav-item nav-item-off">
                <span class="text-[10px] font-mono w-20">{s.label}</span>
                <span class="font-medium">{s.kr}</span>
                <span class="ml-auto text-[9px] font-mono px-1.5 py-0.5 rounded-full bg-[var(--color-surface-2)]">준비 중</span>
              </div>
            ))}
          </div>
        </div>

        <!-- 도구 -->
        <a href={`${base}tools/`} class="nav-link">도구</a>

        <!-- 용어집 -->
        <a href={`${base}glossary/`} class="nav-link">용어집</a>
      </nav>

      <div class="flex items-center gap-2">
        {FEEDBACK_URL && (
          <a href={FEEDBACK_URL} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-1.5 text-sm font-semibold px-3 py-1.5 min-h-[40px] rounded-full border border-[var(--color-border)] text-[var(--color-ink-500)] hover:border-[var(--color-violet)] hover:text-[var(--color-violet)] transition"
            style="font-family:'Space Grotesk','Pretendard',sans-serif" title="의견·버그 제보">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
            <span class="hidden sm:inline">피드백</span>
          </a>
        )}
        <a href={`${base}learn/`}
          class="inline-flex items-center gradient-brand text-white text-sm font-semibold px-4 py-1.5 min-h-[40px] rounded-full transition hover:opacity-90"
          style="font-family:'Space Grotesk','Pretendard',sans-serif">
          시작하기
        </a>
        <button id="mobile-menu-btn" type="button" aria-label="메뉴 열기" aria-expanded="false" aria-controls="mobile-menu"
          class="sm:hidden inline-flex items-center justify-center w-10 h-10 -mr-1.5 rounded-lg text-[var(--color-ink-500)] hover:text-[var(--color-violet)] hover:bg-[var(--color-violet-glow)] transition">
          <svg class="mm-icon-open w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
          <svg class="mm-icon-close w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
      </div>
    </div>

    <!-- 모바일 메뉴 패널 (sm 미만에서만) -->
    <div id="mobile-menu" class="sm:hidden hidden border-t border-[var(--color-border)] bg-white/95 backdrop-blur-md">
      <nav class="max-w-6xl mx-auto px-4 py-3 max-h-[calc(100dvh-3.5rem)] overflow-y-auto flex flex-col gap-0.5">
        <a href={`${base}learn/`} class="mm-head">지식 허브</a>
        <div class="mm-group">
          {hubNav.map(h => h.ready ? (
            <a href={h.href} class="mm-sub"><span class="mm-en">{h.label}</span><span>{h.kr}</span></a>
          ) : (
            <span class="mm-sub mm-off"><span class="mm-en">{h.label}</span><span>{h.kr}</span><span class="mm-badge">준비 중</span></span>
          ))}
        </div>
        <a href={`${base}sandbox/`} class="mm-head">샌드박스</a>
        <div class="mm-group">
          {sandboxNav.map(s => s.ready ? (
            <a href={s.href} class="mm-sub"><span class="mm-en">{s.label}</span><span>{s.kr}</span></a>
          ) : (
            <span class="mm-sub mm-off"><span class="mm-en">{s.label}</span><span>{s.kr}</span><span class="mm-badge">준비 중</span></span>
          ))}
        </div>
        <a href={`${base}tools/`} class="mm-head">도구</a>
        <a href={`${base}glossary/`} class="mm-head">용어집</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="mt-24 border-t border-[var(--color-border)] bg-[var(--color-surface)]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <div class="w-6 h-6 rounded-md gradient-brand flex items-center justify-center">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5">
            <path d="M2 12h3l2-7 3 14 3-10 2 6h7"/>
          </svg>
        </div>
        <span class="text-sm font-semibold gradient-brand-text" style="font-family:'Space Grotesk','Pretendard',sans-serif">SoundLab</span>
      </div>
      <p class="text-xs text-[var(--color-ink-300)] font-mono">Web Audio API · 헤드폰 착용 권장</p>
      <div class="flex items-center gap-2">
        <a href={`${base}about/`} class="inline-flex items-center min-h-[40px] px-2 text-xs text-[var(--color-ink-300)] hover:text-[var(--color-violet)] transition">소개</a>
        <a href={`${base}privacy/`} class="inline-flex items-center min-h-[40px] px-2 text-xs text-[var(--color-ink-300)] hover:text-[var(--color-violet)] transition">개인정보처리방침</a>
      </div>
    </div>
  </footer>

  <script>
    const mmBtn = document.getElementById('mobile-menu-btn');
    const mmPanel = document.getElementById('mobile-menu');
    if (mmBtn && mmPanel) {
      const iconOpen = mmBtn.querySelector('.mm-icon-open');
      const iconClose = mmBtn.querySelector('.mm-icon-close');
      const setOpen = (open: boolean) => {
        mmPanel.classList.toggle('hidden', !open);
        iconOpen?.classList.toggle('hidden', open);
        iconClose?.classList.toggle('hidden', !open);
        mmBtn.setAttribute('aria-expanded', String(open));
        mmBtn.setAttribute('aria-label', open ? '메뉴 닫기' : '메뉴 열기');
      };
      mmBtn.addEventListener('click', () => setOpen(mmPanel.classList.contains('hidden')));
      mmPanel.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('a')) setOpen(false);
      });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') setOpen(false); });
      window.matchMedia('(min-width: 640px)').addEventListener('change', (e) => { if (e.matches) setOpen(false); });
    }
  </script>
</body>
</html>

<style>
  .nav-link {
    font-family: 'Space Grotesk', 'Pretendard', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-ink-500);
    padding: 6px 12px;
    border-radius: 8px;
    transition: color 0.15s, background 0.15s;
  }
  .nav-link:hover {
    color: var(--color-violet);
    background: var(--color-violet-glow);
  }

  /* 모바일 메뉴 */
  .mm-head {
    font-family: 'Space Grotesk', 'Pretendard', sans-serif;
    font-size: 15px; font-weight: 600;
    color: var(--color-ink-500);
    padding: 11px 12px; border-radius: 10px;
  }
  .mm-head:active { background: var(--color-violet-glow); color: var(--color-violet); }
  .mm-group { display: flex; flex-direction: column; padding: 2px 0 6px 6px; }
  .mm-sub {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 12px; border-radius: 9px;
    font-size: 14px; font-weight: 500; color: var(--color-ink-500);
  }
  .mm-sub:active { background: var(--color-violet-glow); color: var(--color-violet); }
  .mm-en {
    font-family: ui-monospace, 'Space Grotesk', monospace;
    font-size: 10px; color: var(--color-ink-300);
    width: 74px; flex: none;
  }
  .mm-off { color: var(--color-ink-300); }
  .mm-badge {
    margin-left: auto; font-size: 9px; font-family: ui-monospace, monospace;
    padding: 2px 7px; border-radius: 999px; background: var(--color-surface-2);
  }

  /* 드롭다운 */
  .nav-panel {
    position: absolute;
    top: 100%;
    left: 0;
    margin-top: 6px;
    min-width: 248px;
    padding: 6px;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    box-shadow: 0 12px 32px -12px rgba(15, 15, 26, 0.18);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.15s, transform 0.15s, visibility 0.15s;
    z-index: 60;
  }
  .nav-dd:hover .nav-panel,
  .nav-dd:focus-within .nav-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .nav-dd:hover .nav-chev,
  .nav-dd:focus-within .nav-chev {
    transform: rotate(180deg);
  }
  .nav-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    border-radius: 9px;
    font-size: 14px;
    color: var(--color-ink-700);
    transition: background 0.12s, color 0.12s;
  }
  a.nav-item:hover {
    background: var(--color-violet-glow);
    color: var(--color-violet);
  }
  .nav-item-off {
    color: var(--color-ink-300);
    cursor: default;
  }
  .nav-item > .font-mono { white-space: nowrap; }
</style>
