---
// 소리의 3요소 위젯 — 단일 오실레이터의 주파수(음높이)·진폭(음량)·파형(음색).
// AudioCore 위 osc→gain→core.input. 파형/스펙트럼 시각화.
interface Props {
  config?: Record<string, any>;
}
const { config = {} } = Astro.props;
const c = { freq: config.freq ?? 220, amp: config.amp ?? 50, wave: config.wave ?? 'sine' };
const waves: [OscillatorType, string][] = [['sine','Sine'],['square','Square'],['sawtooth','Saw'],['triangle','Tri']];
const adv = (tier?: string) => (tier && tier !== 'easy' ? { 'data-adv': tier } : {});
---
<div class="tone-widget rounded-2xl border border-[var(--color-border)] bg-white overflow-hidden"
  data-freq={c.freq} data-amp={c.amp} data-wave={c.wave}>

  <div class="flex items-center justify-between px-5 py-4 border-b border-[var(--color-border)] bg-[var(--color-surface)]">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg flex items-center justify-center gradient-brand">
        <svg class="text-white" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c2.5 0 2.5-7 5-7s2.5 14 5 14 2.5-7 5-7 2.5 7 5 7"/></svg>
      </div>
      <div>
        <span class="font-bold text-base" style="font-family:'Space Grotesk'">소리의 3요소</span>
        <span class="text-sm text-[var(--color-ink-300)] ml-2">Tone</span>
      </div>
    </div>
    <button class="play-btn gradient-brand text-white text-sm font-semibold px-4 py-1.5 rounded-full transition hover:opacity-90" style="font-family:'Space Grotesk'">▶ 소리 켜기</button>
  </div>

  <div class="p-5 space-y-4">
    <!-- 파형 -->
    <div class="relative rounded-xl overflow-hidden bg-[var(--color-surface-2)] border border-[var(--color-border)]">
      <canvas class="scope-cv block w-full" style="height:110px"></canvas>
      <span class="absolute top-2 left-2.5 text-[10px] font-mono uppercase tracking-wider text-[var(--color-violet)] opacity-70">Waveform · 파형</span>
    </div>
    <!-- 스펙트럼 (normal↑: 음색=배음) -->
    <div class="relative rounded-xl overflow-hidden bg-[var(--color-surface-2)] border border-[var(--color-border)]" {...adv('normal')}>
      <canvas class="spec-cv block w-full" style="height:90px"></canvas>
      <span class="absolute top-2 left-2.5 text-[10px] font-mono uppercase tracking-wider text-[var(--color-blue)] opacity-70">Spectrum · 배음</span>
    </div>

    <!-- 음높이 -->
    <div>
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">Frequency · 음높이</span>
        <span class="freq-val text-sm font-mono text-[var(--color-ink-700)]">{c.freq}Hz</span>
      </div>
      <input type="range" class="sl-range freq-range" min="80" max="880" step="1" value={c.freq} aria-label="주파수" />
    </div>
    <!-- 음량 -->
    <div>
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">Amplitude · 음량</span>
        <span class="amp-val text-sm font-mono text-[var(--color-ink-700)]">{c.amp}%</span>
      </div>
      <input type="range" class="sl-range amp-range" min="0" max="100" step="1" value={c.amp} aria-label="음량" />
    </div>
    <!-- 음색(파형) -->
    <div>
      <div class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)] mb-1.5">Waveform · 음색</div>
      <div class="flex gap-1 p-1 bg-[var(--color-surface-2)] rounded-xl" role="group">
        {waves.map(([v, t]) => (
          <button class="wave-btn px-3 py-1.5 rounded-lg text-xs font-semibold transition-all text-[var(--color-ink-500)]"
            data-wave={v} aria-pressed={v === c.wave ? 'true' : 'false'} style="font-family:'Space Grotesk'">{t}</button>
        ))}
      </div>
    </div>
  </div>
</div>

<script>
import { AudioCore } from '../audio/core';

function initTone(root: HTMLElement) {
  const core = new AudioCore();
  let freq = Number(root.dataset.freq) || 220;
  let amp = Number(root.dataset.amp) || 50;
  let wave = (root.dataset.wave as OscillatorType) || 'sine';
  let playing = false;

  const g = core.gain(amp / 100 * 0.6);
  g.connect(core.input);
  let osc: OscillatorNode | null = null;

  async function start() {
    await core.resume();
    osc = core.ctx.createOscillator(); osc.type = wave; osc.frequency.value = freq; osc.connect(g); osc.start();
    playing = true;
  }
  function stop() { if (osc) { try { osc.stop(); } catch (e) {} osc.disconnect(); osc = null; } playing = false; }

  const scope = root.querySelector('.scope-cv') as HTMLCanvasElement;
  const spec = root.querySelector('.spec-cv') as HTMLCanvasElement;
  const fit = (cv: HTMLCanvasElement) => { const r = cv.getBoundingClientRect(); cv.width = Math.max(1, r.width * devicePixelRatio); cv.height = Math.max(1, r.height * devicePixelRatio); };
  fit(scope); fit(spec);
  addEventListener('resize', () => { fit(scope); fit(spec); });

  const td = new Uint8Array(core.analyser.fftSize);
  const fd = new Uint8Array(core.analyser.frequencyBinCount);
  function draw() {
    // 파형
    let ctx = scope.getContext('2d')!; let W = scope.width, H = scope.height;
    core.analyser.getByteTimeDomainData(td);
    ctx.clearRect(0, 0, W, H); ctx.beginPath();
    for (let i = 0; i < td.length; i++) { const x = (i / td.length) * W, y = (td[i] / 255) * H; i ? ctx.lineTo(x, y) : ctx.moveTo(x, y); }
    ctx.strokeStyle = '#7c3aed'; ctx.lineWidth = 1.6 * devicePixelRatio; ctx.stroke();
    // 스펙트럼 (배음 막대)
    ctx = spec.getContext('2d')!; W = spec.width; H = spec.height;
    core.analyser.getByteFrequencyData(fd);
    ctx.clearRect(0, 0, W, H);
    const bins = 64, bw = W / bins;
    for (let i = 0; i < bins; i++) {
      const v = fd[i] / 255, bh = v * H;
      ctx.fillStyle = `rgba(37,99,235,${0.35 + v * 0.5})`;
      ctx.fillRect(i * bw, H - bh, bw * 0.8, bh);
    }
    requestAnimationFrame(draw);
  }
  draw();

  // 컨트롤
  const playBtn = root.querySelector('.play-btn') as HTMLButtonElement;
  playBtn.addEventListener('click', async () => {
    if (playing) { stop(); playBtn.textContent = '▶ 소리 켜기'; }
    else { await start(); playBtn.textContent = '⏸ 소리 끄기'; }
  });

  const setPct = (el: HTMLInputElement) => el.style.setProperty('--sl-pct', ((+el.value - +el.min) / (+el.max - +el.min) * 100) + '%');
  const freqRange = root.querySelector('.freq-range') as HTMLInputElement;
  const freqVal = root.querySelector('.freq-val') as HTMLElement;
  setPct(freqRange);
  freqRange.addEventListener('input', () => { freq = +freqRange.value; freqVal.textContent = freq + 'Hz'; setPct(freqRange); if (osc) core.smooth(osc.frequency, freq); });

  const ampRange = root.querySelector('.amp-range') as HTMLInputElement;
  const ampVal = root.querySelector('.amp-val') as HTMLElement;
  setPct(ampRange);
  ampRange.addEventListener('input', () => { amp = +ampRange.value; ampVal.textContent = amp + '%'; setPct(ampRange); core.smooth(g.gain, amp / 100 * 0.6); });

  root.querySelectorAll<HTMLButtonElement>('.wave-btn').forEach(btn => {
    const sel = () => { btn.style.cssText = 'background:white;color:var(--color-violet);box-shadow:0 1px 4px rgba(0,0,0,0.08)'; };
    btn.addEventListener('click', () => {
      root.querySelectorAll('.wave-btn').forEach(b => { (b as HTMLElement).setAttribute('aria-pressed','false'); (b as HTMLElement).style.cssText = ''; });
      btn.setAttribute('aria-pressed','true'); sel();
      wave = btn.dataset.wave as OscillatorType; if (osc) osc.type = wave;
    });
    if (btn.getAttribute('aria-pressed') === 'true') sel();
  });
}

document.querySelectorAll<HTMLElement>('.tone-widget').forEach(initTone);
</script>
