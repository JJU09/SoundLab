---
import Base from '../../layouts/Base.astro';
const base = import.meta.env.BASE_URL;
const desc = '마이크로 음정을 실시간 잡아주는 무료 온라인 크로마틱 튜너. 기타·바이올린·관악 등 모든 악기. 음이름·주파수·센트 편차 표시.';
---
<Base title="크로마틱 튜너" description={desc} type="website"
  breadcrumbs={[{ name: '홈', url: base }, { name: '도구', url: `${base}tools/` }, { name: '크로마틱 튜너', url: Astro.url.pathname }]}>

<div class="max-w-xl mx-auto px-4 sm:px-6 py-12">
  <nav class="flex items-center gap-2 text-xs font-mono text-[var(--color-ink-300)] mb-6">
    <a href={base} class="hover:text-[var(--color-violet)] transition">홈</a><span>/</span>
    <a href={`${base}tools/`} class="hover:text-[var(--color-violet)] transition">도구</a><span>/</span>
    <span class="text-[var(--color-ink-700)]">크로마틱 튜너</span>
  </nav>

  <div class="mb-6">
    <span class="text-xs font-mono px-2.5 py-1 rounded-full border border-[var(--color-violet-light)] text-[var(--color-violet)] bg-[var(--color-violet-glow)]">TOOLS</span>
    <h1 class="text-3xl font-bold mt-3 mb-2" style="font-family:'Space Grotesk','Pretendard',sans-serif">크로마틱 튜너</h1>
    <p class="text-[var(--color-ink-500)]">마이크에 소리를 내면 음이름·주파수·센트 편차를 실시간으로 잡아줍니다. 모든 악기·목소리.</p>
  </div>

  <div class="tuner rounded-2xl border border-[var(--color-border)] bg-white overflow-hidden">
    <div class="p-6 sm:p-8 space-y-6">
      <!-- 음이름 + 센트 -->
      <div class="text-center">
        <div class="note-name text-7xl font-bold leading-none tabular-nums" style="font-family:'Space Grotesk','Pretendard',sans-serif">–</div>
        <div class="note-freq text-sm font-mono text-[var(--color-ink-300)] mt-2">마이크를 켜고 소리를 내보세요</div>
      </div>

      <!-- 센트 미터 (-50 ~ +50) -->
      <div>
        <div class="relative h-14 rounded-xl bg-[var(--color-surface-2)] border border-[var(--color-border)] overflow-hidden">
          <!-- 눈금 -->
          <div class="absolute inset-y-0 left-1/2 w-0.5 -translate-x-1/2 bg-[var(--color-violet)] opacity-40"></div>
          <div class="absolute inset-y-0 left-[10%] w-px bg-[var(--color-border)]"></div>
          <div class="absolute inset-y-0 left-[30%] w-px bg-[var(--color-border)]"></div>
          <div class="absolute inset-y-0 left-[70%] w-px bg-[var(--color-border)]"></div>
          <div class="absolute inset-y-0 left-[90%] w-px bg-[var(--color-border)]"></div>
          <!-- 바늘 -->
          <div class="needle absolute top-1.5 bottom-1.5 w-1 rounded-full bg-[var(--color-ink-300)] left-1/2 -translate-x-1/2 transition-[left,background-color] duration-75" style="left:50%"></div>
        </div>
        <div class="flex justify-between text-[10px] font-mono text-[var(--color-ink-300)] mt-1 px-0.5">
          <span>-50</span><span>낮음 ♭</span><span class="cents-val text-[var(--color-ink-700)]">— cent</span><span>높음 ♯</span><span>+50</span>
        </div>
      </div>

      <!-- 마이크 토글 -->
      <button class="mic-btn w-full gradient-brand text-white font-semibold py-3.5 rounded-xl text-base flex items-center justify-center gap-2 transition hover:opacity-90" style="font-family:'Space Grotesk','Pretendard',sans-serif">
        🎤 마이크 켜기
      </button>
      <div class="mic-err hidden text-center text-sm text-[#b91c1c] font-medium"></div>

      <!-- 기준음 캘리브레이션 + 악기 줄 기준음 -->
      <div class="pt-4 mt-2 border-t border-[var(--color-border)] space-y-4">
        <div class="flex items-center justify-between">
          <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">기준음 A4</span>
          <div class="flex items-center gap-2">
            <button class="a4-dec w-7 h-7 rounded-lg border border-[var(--color-border)] text-base font-bold text-[var(--color-ink-500)] hover:border-[var(--color-violet)] hover:text-[var(--color-violet)] transition" aria-label="기준음 감소">−</button>
            <span class="a4-val text-sm font-mono text-[var(--color-ink-700)] w-16 text-center">440 Hz</span>
            <button class="a4-inc w-7 h-7 rounded-lg border border-[var(--color-border)] text-base font-bold text-[var(--color-ink-500)] hover:border-[var(--color-violet)] hover:text-[var(--color-violet)] transition" aria-label="기준음 증가">+</button>
          </div>
        </div>
        <div>
          <div class="flex items-center justify-between mb-2">
            <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">기준음 듣기</span>
            <div class="inst-tabs flex gap-1 p-1 bg-[var(--color-surface-2)] rounded-lg" role="group" aria-label="악기">
              {[['guitar','기타'],['bass','베이스'],['ukulele','우쿨렐레']].map(([k,t]) => (
                <button class="inst-btn px-2.5 py-1 rounded-md text-[11px] font-semibold transition-all text-[var(--color-ink-500)]" data-inst={k} aria-pressed={k==='guitar'?'true':'false'} style="font-family:'Space Grotesk','Pretendard',sans-serif">{t}</button>
              ))}
            </div>
          </div>
          <div class="string-row flex flex-wrap gap-1.5"></div>
        </div>
      </div>
    </div>
  </div>

  <p class="text-xs text-[var(--color-ink-300)] mt-4 text-center">
    초록이 되면 음이 맞은 것 · 기준음 A4는 기본 440Hz(아래에서 조정) · 권한 요청 시 <b class="text-[var(--color-ink-500)]">허용</b>을 눌러야 마이크가 켜집니다
  </p>

  <div class="mt-8 p-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] text-sm text-[var(--color-ink-500)]">
    두 음을 맞출 때 들리는 맥놀이로 귀로 튜닝하는 원리는 <a href={`${base}learn/acoustics/beats/`} class="text-[var(--color-violet)] font-medium hover:underline">맥놀이</a>,
    음높이·주파수 관계는 <a href={`${base}learn/acoustics/tone/`} class="text-[var(--color-violet)] font-medium hover:underline">소리의 3요소</a>에서.
  </div>
</div>

<script>
const NOTES = ['C','C♯','D','D♯','E','F','F♯','G','G♯','A','A♯','B'];

// autocorrelation 피치 검출 (Float32 시간축 → 기본 주파수 Hz, 무음/불명확이면 -1)
function detectPitch(buf: Float32Array, sr: number): number {
  const SIZE = buf.length;
  let rms = 0;
  for (let i = 0; i < SIZE; i++) rms += buf[i] * buf[i];
  rms = Math.sqrt(rms / SIZE);
  if (rms < 0.01) return -1; // 너무 조용함
  let r1 = 0, r2 = SIZE - 1, thres = 0.2;
  for (let i = 0; i < SIZE / 2; i++) if (Math.abs(buf[i]) < thres) { r1 = i; break; }
  for (let i = 1; i < SIZE / 2; i++) if (Math.abs(buf[SIZE - i]) < thres) { r2 = SIZE - i; break; }
  const b = buf.slice(r1, r2), N = b.length;
  const c = new Array(N).fill(0);
  for (let lag = 0; lag < N; lag++) { let sum = 0; for (let i = 0; i < N - lag; i++) sum += b[i] * b[i + lag]; c[lag] = sum; }
  let d = 0; while (d < N - 1 && c[d] > c[d + 1]) d++;
  let maxval = -1, maxpos = -1;
  for (let i = d; i < N; i++) if (c[i] > maxval) { maxval = c[i]; maxpos = i; }
  let T0 = maxpos;
  if (T0 <= 0) return -1;
  const x1 = c[T0 - 1] || 0, x2 = c[T0], x3 = c[T0 + 1] || 0;
  const a = (x1 + x3 - 2 * x2) / 2, bb = (x3 - x1) / 2;
  if (a) T0 = T0 - bb / (2 * a);
  return sr / T0;
}

function initTuner(root: HTMLElement) {
  const nameEl = root.querySelector('.note-name') as HTMLElement;
  const freqEl = root.querySelector('.note-freq') as HTMLElement;
  const needle = root.querySelector('.needle') as HTMLElement;
  const centsEl = root.querySelector('.cents-val') as HTMLElement;
  const micBtn = root.querySelector('.mic-btn') as HTMLButtonElement;
  const errEl = root.querySelector('.mic-err') as HTMLElement;

  let ctx: AudioContext | null = null, stream: MediaStream | null = null, raf = 0, running = false;
  let buf: Float32Array<ArrayBuffer>, analyser: AnalyserNode;
  let smoothFreq = 0;
  let a4 = 440; // 기준음(캘리브레이션). 피치 검출·기준음 재생 공용.

  async function startMic() {
    try {
      ctx = new (window.AudioContext || (window as any).webkitAudioContext)();
      stream = await navigator.mediaDevices.getUserMedia({ audio: { echoCancellation: false, noiseSuppression: false, autoGainControl: false } });
      const src = ctx.createMediaStreamSource(stream);
      analyser = ctx.createAnalyser(); analyser.fftSize = 2048;
      buf = new Float32Array(analyser.fftSize);
      src.connect(analyser); // destination에 연결 안 함(피드백 방지)
      running = true; errEl.classList.add('hidden');
      micBtn.textContent = '⏹ 마이크 끄기';
      loop();
    } catch (e: any) {
      errEl.textContent = e?.name === 'NotAllowedError' ? '마이크 권한이 거부됐어요. 브라우저 주소창의 권한을 허용으로 바꿔주세요.' : '마이크를 열 수 없습니다: ' + (e?.message || e);
      errEl.classList.remove('hidden');
    }
  }
  function stopMic() {
    running = false; cancelAnimationFrame(raf);
    stream?.getTracks().forEach(t => t.stop()); ctx?.close();
    ctx = null; stream = null; smoothFreq = 0;
    micBtn.textContent = '🎤 마이크 켜기';
    nameEl.textContent = '–'; freqEl.textContent = '마이크를 켜고 소리를 내보세요';
    centsEl.textContent = '— cent'; needle.style.left = '50%'; needle.style.background = 'var(--color-ink-300)';
  }

  function loop() {
    if (!running) return;
    raf = requestAnimationFrame(loop);
    analyser.getFloatTimeDomainData(buf);
    const f = detectPitch(buf, ctx!.sampleRate);
    if (f < 0 || f < 30 || f > 5000) return; // 무음/범위 밖 → 직전 표시 유지
    smoothFreq = smoothFreq ? smoothFreq * 0.8 + f * 0.2 : f; // 떨림 완화
    const midi = Math.round(12 * Math.log2(smoothFreq / a4) + 69);
    const target = a4 * Math.pow(2, (midi - 69) / 12);
    const cents = Math.round(1200 * Math.log2(smoothFreq / target));
    nameEl.textContent = NOTES[((midi % 12) + 12) % 12] + (Math.floor(midi / 12) - 1);
    freqEl.textContent = smoothFreq.toFixed(1) + ' Hz  ·  목표 ' + target.toFixed(1) + ' Hz';
    centsEl.textContent = (cents > 0 ? '+' : '') + cents + ' cent';
    const clamped = Math.max(-50, Math.min(50, cents));
    needle.style.left = ((clamped + 50) / 100 * 100) + '%';
    const inTune = Math.abs(cents) <= 5;
    needle.style.background = inTune ? '#22c55e' : Math.abs(cents) <= 15 ? '#f59e0b' : '#ef4444';
    nameEl.style.color = inTune ? '#22c55e' : 'var(--color-ink-700)';
  }

  micBtn.addEventListener('click', () => running ? stopMic() : startMic());

  // ── 기준음 캘리브레이션 ──
  const a4Val = root.querySelector('.a4-val') as HTMLElement;
  const setA4 = (v: number) => { a4 = Math.max(430, Math.min(450, Math.round(v))); a4Val.textContent = a4 + ' Hz'; };
  root.querySelector('.a4-dec')!.addEventListener('click', () => setA4(a4 - 1));
  root.querySelector('.a4-inc')!.addEventListener('click', () => setA4(a4 + 1));

  // ── 악기 줄 기준음 재생 (마이크와 별개 AudioContext, 지연 생성) ──
  const TUNINGS: Record<string, { n: string; m: number }[]> = {
    guitar: [{ n: 'E', m: 40 }, { n: 'A', m: 45 }, { n: 'D', m: 50 }, { n: 'G', m: 55 }, { n: 'B', m: 59 }, { n: 'E', m: 64 }],
    bass: [{ n: 'E', m: 28 }, { n: 'A', m: 33 }, { n: 'D', m: 38 }, { n: 'G', m: 43 }],
    ukulele: [{ n: 'G', m: 67 }, { n: 'C', m: 60 }, { n: 'E', m: 64 }, { n: 'A', m: 69 }],
  };
  let refCtx: AudioContext | null = null;
  function playRef(midi: number) {
    if (!refCtx) refCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
    refCtx.resume();
    const freq = a4 * Math.pow(2, (midi - 69) / 12);
    const o = refCtx.createOscillator(); o.type = 'sine'; o.frequency.value = freq;
    const g = refCtx.createGain(); const t = refCtx.currentTime;
    g.gain.setValueAtTime(0.0001, t);
    g.gain.exponentialRampToValueAtTime(0.25, t + 0.02);
    g.gain.setValueAtTime(0.25, t + 1.1);
    g.gain.exponentialRampToValueAtTime(0.0001, t + 1.6);
    o.connect(g); g.connect(refCtx.destination);
    o.start(t); o.stop(t + 1.65);
    o.onended = () => { try { o.disconnect(); g.disconnect(); } catch (e) {} };
  }
  const stringRow = root.querySelector('.string-row') as HTMLElement;
  function buildStrings(inst: string) {
    stringRow.innerHTML = '';
    TUNINGS[inst].forEach(s => {
      const b = document.createElement('button');
      b.className = 'flex-1 min-w-[40px] py-2 rounded-lg border border-[var(--color-border)] text-sm font-bold text-[var(--color-ink-700)] hover:border-[var(--color-violet)] hover:text-[var(--color-violet)] transition';
      b.textContent = s.n + (Math.floor(s.m / 12) - 1);
      b.setAttribute('aria-label', s.n + ' 기준음 재생');
      b.addEventListener('click', () => { playRef(s.m); b.style.cssText = 'border-color:var(--color-violet);color:var(--color-violet);background:var(--color-violet-glow)'; setTimeout(() => b.style.cssText = '', 300); });
      stringRow.appendChild(b);
    });
  }
  const instBtns = [...root.querySelectorAll<HTMLElement>('.inst-btn')];
  instBtns.forEach(btn => {
    const sel = () => btn.style.cssText = 'background:white;color:var(--color-violet);box-shadow:0 1px 4px rgba(0,0,0,0.08)';
    btn.addEventListener('click', () => {
      instBtns.forEach(b => { b.setAttribute('aria-pressed', 'false'); b.style.cssText = ''; });
      btn.setAttribute('aria-pressed', 'true'); sel();
      buildStrings(btn.dataset.inst!);
    });
    if (btn.getAttribute('aria-pressed') === 'true') sel();
  });
  buildStrings('guitar');
}

document.querySelectorAll<HTMLElement>('.tuner').forEach(initTuner);
</script>

</Base>
