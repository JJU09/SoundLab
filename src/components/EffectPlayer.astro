---
import type { ModuleDef } from '../lib/modules';

interface Props {
  module: ModuleDef;
}
const { module: m } = Astro.props;
// 수준별 노출 태그: easy/없음=항상, normal=중급↑, hard=고급만 (CSS가 data-level과 매칭해 숨김)
const adv = (tier?: string) => (tier && tier !== 'easy' ? { 'data-adv': tier } : {});
---

<div class="effect-player rounded-2xl border border-[var(--color-border)] bg-white overflow-hidden"
  data-module-id={m.id}
  data-default-src={m.defaultSrc}
  data-default-wave={m.defaultWave ?? ''}>

  <!-- 헤더 -->
  <div class="flex items-center justify-between px-5 py-4 border-b border-[var(--color-border)] bg-[var(--color-surface)]">
    <div class="flex items-center gap-3">
      <div class={`w-8 h-8 rounded-lg flex items-center justify-center text-xs font-mono font-bold text-white gradient-brand`}>
        {m.num}
      </div>
      <div>
        <span class="font-bold text-base" style="font-family:'Space Grotesk','Pretendard',sans-serif">{m.name}</span>
        <span class="text-sm text-[var(--color-ink-300)] ml-2">{m.kr}</span>
      </div>
    </div>
    <!-- 전원 토글 -->
    <button
      class="pwr-btn flex items-center gap-2 px-3 py-1.5 rounded-full border text-xs font-mono font-medium transition-all"
      aria-pressed="true"
      aria-label={`${m.name} 켜기/끄기`}
      style="border-color:var(--color-violet);color:var(--color-violet);background:var(--color-violet-glow)">
      <span class="pwr-dot w-2 h-2 rounded-full transition-all"
        style="background:var(--color-violet);box-shadow:0 0 8px var(--color-violet)"></span>
      <span class="pwr-label">ON</span>
    </button>
  </div>

  <!-- 타입 선택 (Filter만) -->
  {m.type && (
    <div class="px-5 pt-4" {...adv(m.type.tier)}>
      <div class="flex gap-1.5 p-1 bg-[var(--color-surface-2)] rounded-xl w-fit" role="group" aria-label="필터 타입">
        {m.type.options.map(([val, txt]) => (
          <button
            class="type-btn px-3 py-1.5 rounded-lg text-xs font-mono font-medium transition-all text-[var(--color-ink-500)]"
            data-val={val}
            aria-pressed={val === m.type!.value ? 'true' : 'false'}>
            {txt}
          </button>
        ))}
      </div>
    </div>
  )}

  <!-- 추가 셀렉터 (예: 필터 Slope · 고급) -->
  {m.selectors?.map(sel => (
    <div class="px-5 pt-3" {...adv(sel.tier)}>
      <div class="text-[10px] font-mono uppercase tracking-wider text-[var(--color-ink-300)] mb-1.5">{sel.label}</div>
      <div class="sel-group flex gap-1.5 p-1 bg-[var(--color-surface-2)] rounded-xl w-fit" role="group" data-sel-param={sel.param}>
        {sel.options.map(([val, txt]) => (
          <button class="sel-btn px-3 py-1.5 rounded-lg text-xs font-mono font-medium transition-all text-[var(--color-ink-500)]"
            data-val={val} aria-pressed={val === sel.value ? 'true' : 'false'}>
            {txt}
          </button>
        ))}
      </div>
    </div>
  ))}

  <!-- 슬라이더들 -->
  <div class="px-5 py-5 flex flex-col gap-5">
    {m.knobs.map(k => (
      <div class="slider-wrap" data-param={k.param} {...adv(k.tier)}
        data-min={k.min} data-max={k.max} data-value={k.value} data-curve={k.curve ?? 'lin'}>
        <div class="flex items-center justify-between mb-2">
          <label class="text-xs font-mono uppercase tracking-widest text-[var(--color-ink-500)]">{k.label}</label>
          <span class="val-display text-sm font-mono font-medium text-[var(--color-ink-700)]">—</span>
        </div>
        <input type="range" class="sl-range w-full" min="0" max="1000" step="1"
          aria-label={k.label} />
      </div>
    ))}
  </div>

  <!-- 비주얼라이저 -->
  {m.id === 'filter' ? (
    <!-- Filter: 스펙트럼 메인 + 웨이브폼 작게 -->
    <div class="px-5 pb-2 flex flex-col gap-2">
      <div class="relative rounded-xl overflow-hidden bg-[var(--color-surface-2)] border border-[var(--color-border)]">
        <canvas class="spectrum-canvas block w-full" style="height:130px"></canvas>
        <span class="absolute top-2 left-2.5 text-[10px] font-mono uppercase tracking-wider text-[var(--color-blue)] opacity-70 pointer-events-none">Spectrum · 드래그로 Cutoff/Q 조절</span>
      </div>
      <div class="relative rounded-xl overflow-hidden bg-[var(--color-surface-2)] border border-[var(--color-border)]">
        <canvas class="scope-canvas block w-full" style="height:60px"></canvas>
        <span class="absolute top-1.5 left-2.5 text-[10px] font-mono uppercase tracking-wider text-[var(--color-violet)] opacity-70">Waveform</span>
      </div>
    </div>
  ) : (m.id === 'delay' || m.id === 'reverb') ? (
    <!-- Delay/Reverb: 웨이브폼 + 스크롤 엔벨로프 -->
    <div class="px-5 pb-2 flex flex-col gap-2">
      <div class="grid grid-cols-2 gap-2">
        <div class="relative rounded-xl overflow-hidden bg-[var(--color-surface-2)] border border-[var(--color-border)]">
          <canvas class="scope-canvas block w-full" style="height:80px"></canvas>
          <span class="absolute top-1.5 left-2.5 text-[10px] font-mono uppercase tracking-wider text-[var(--color-violet)] opacity-70">Waveform</span>
        </div>
        <div class="relative rounded-xl overflow-hidden bg-[var(--color-surface-2)] border border-[var(--color-border)]">
          <canvas class="spectrum-canvas block w-full" style="height:80px"></canvas>
          <span class="absolute top-1.5 left-2.5 text-[10px] font-mono uppercase tracking-wider text-[var(--color-blue)] opacity-70">Spectrum</span>
        </div>
      </div>
      <div class="relative rounded-xl overflow-hidden bg-[var(--color-surface-2)] border border-[var(--color-border)]">
        <canvas class="envelope-canvas block w-full" style="height:56px"></canvas>
        <span class="absolute top-1.5 left-2.5 text-[10px] font-mono uppercase tracking-wider opacity-70"
          style={`color:${m.id === 'delay' ? 'var(--color-violet)' : 'var(--color-blue)'}`}>
          Envelope · 시간 흐름
        </span>
      </div>
    </div>
  ) : (
    <!-- 기본: 좌우 동일 크기 -->
    <div class="px-5 pb-2 grid grid-cols-2 gap-3">
      <div class="relative rounded-xl overflow-hidden bg-[var(--color-surface-2)] border border-[var(--color-border)]">
        <canvas class="scope-canvas block w-full" style="height:100px"></canvas>
        <span class="absolute top-2 left-2.5 text-[10px] font-mono uppercase tracking-wider text-[var(--color-violet)] opacity-70">Waveform</span>
      </div>
      <div class="relative rounded-xl overflow-hidden bg-[var(--color-surface-2)] border border-[var(--color-border)]">
        <canvas class="spectrum-canvas block w-full" style="height:100px"></canvas>
        <span class="absolute top-2 left-2.5 text-[10px] font-mono uppercase tracking-wider text-[var(--color-blue)] opacity-70">Spectrum</span>
      </div>
    </div>
  )}
  <!-- 파형 줌 슬라이더 -->
  <div class="px-5 pb-4 flex items-center gap-3">
    <span class="text-[10px] font-mono uppercase tracking-wider text-[var(--color-ink-300)] whitespace-nowrap">파형 줌</span>
    <input type="range" class="scope-speed sl-range flex-1" min="64" max="2048" step="64" value="512" aria-label="파형 줌" />
    <span class="scope-speed-val text-[11px] font-mono text-[var(--color-ink-500)] w-10 text-right">보통</span>
  </div>

  <!-- 음원 선택 -->
  <div class="px-5 pb-3 flex flex-col gap-2">
    <div class="flex gap-1 p-1 bg-[var(--color-surface-2)] rounded-xl w-fit" role="group" aria-label="음원">
      {[['tone','지속음'],['pluck','플럭'],['noise','노이즈']].map(([v,t]) => (
        <button class="src-btn px-3 py-1.5 rounded-lg text-xs font-semibold transition-all text-[var(--color-ink-500)]"
          data-src={v} aria-pressed={v === m.defaultSrc ? 'true' : 'false'}
          style="font-family:'Space Grotesk','Pretendard',sans-serif">
          {t}
        </button>
      ))}
    </div>
    <!-- 파형 선택 (tone일 때만 표시) -->
    <div class="wave-row flex gap-1 p-1 bg-[var(--color-surface-2)] rounded-xl w-fit"
      role="group" aria-label="파형"
      style={m.defaultSrc !== 'tone' ? 'display:none' : ''}>
      {[['sine','Sine'],['square','Square'],['sawtooth','Saw'],['triangle','Tri']].map(([v,t]) => (
        <button class="wave-btn px-2.5 py-1.5 rounded-lg text-[11px] font-mono transition-all text-[var(--color-ink-500)]"
          data-wave={v}
          aria-pressed={v === (m.defaultWave ?? 'sine') ? 'true' : 'false'}>
          {t}
        </button>
      ))}
    </div>
  </div>

  <!-- 재생 버튼 -->
  <div class="px-5 pb-5">
    <button class="play-btn w-full gradient-brand text-white font-semibold px-5 py-2.5 rounded-xl text-sm flex items-center justify-center gap-2 transition hover:opacity-90"
      style="font-family:'Space Grotesk','Pretendard',sans-serif">
      <span class="play-dot w-2 h-2 rounded-full bg-white"></span>
      <span class="play-label">소리 켜기</span>
    </button>
  </div>
</div>

<script>
import { Engine } from '../lib/engine';

document.querySelectorAll<HTMLElement>('.effect-player').forEach(el => {
  const moduleId = el.dataset.moduleId!;
  const defaultSrc = (el.dataset.defaultSrc ?? 'tone') as 'tone' | 'pluck' | 'noise';
  const defaultWave = (el.dataset.defaultWave || 'sine') as OscillatorType;
  let engine: Engine | null = null;

  // 추천 소스 버튼 초기 스타일 적용
  el.querySelectorAll<HTMLButtonElement>('.src-btn').forEach(btn => {
    if (btn.getAttribute('aria-pressed') === 'true') {
      btn.style.cssText = 'background:white;color:var(--color-violet);box-shadow:0 1px 4px rgba(0,0,0,0.08)';
    }
  });
  // 추천 파형 버튼 초기 선택
  if (defaultSrc === 'tone' && defaultWave) {
    el.querySelectorAll<HTMLButtonElement>('.wave-btn').forEach(btn => {
      const isDefault = btn.dataset.wave === defaultWave;
      btn.setAttribute('aria-pressed', String(isDefault));
      if (isDefault) btn.style.cssText = 'background:white;color:var(--color-violet);box-shadow:0 1px 4px rgba(0,0,0,0.08)';
    });
  }

  // 슬라이더 초기화
  const sliders = el.querySelectorAll<HTMLElement>('.slider-wrap');

  function logMap(p: number, min: number, max: number, curve: string): number {
    if (curve === 'log') return min * Math.pow(max / min, p);
    return min + (max - min) * p;
  }

  function toP(v: number, min: number, max: number, curve: string): number {
    if (curve === 'log') return Math.log(v / min) / Math.log(max / min);
    return (v - min) / (max - min);
  }

  // param → 슬라이더 메타 (Canvas 드래그 등 외부 제어용)
  const sliderMap: Record<string, { input: HTMLInputElement; valEl: HTMLElement; min: number; max: number; curve: string; fmt: (v: number) => string }> = {};

  sliders.forEach(wrap => {
    const input = wrap.querySelector<HTMLInputElement>('input')!;
    const valEl = wrap.querySelector<HTMLElement>('.val-display')!;
    const param = wrap.dataset.param!;
    const min = parseFloat(wrap.dataset.min!);
    const max = parseFloat(wrap.dataset.max!);
    const def = parseFloat(wrap.dataset.value!);
    const curve = wrap.dataset.curve!;

    // 초기값 세팅
    const initP = toP(def, min, max, curve);
    input.value = String(Math.round(initP * 1000));
    input.style.setProperty('--sl-pct', `${initP * 100}%`);

    // fmt 함수는 data-unit 없이 값으로 추정
    const fmt = (v: number) => {
      if (param === 'freq') return v >= 1000 ? (v/1000).toFixed(1)+'kHz' : Math.round(v)+'Hz';
      if (param === 'time') return v < 1 ? Math.round(v*1000)+'ms' : v.toFixed(2)+'s';
      if (param === 'rate') return v.toFixed(1)+'Hz';
      if (param === 'size') return v.toFixed(1)+'s';
      if (param === 'q') return v.toFixed(1);
      return Math.round(v)+'%';
    };
    valEl.textContent = fmt(def);
    sliderMap[param] = { input, valEl, min, max, curve, fmt };

    input.addEventListener('input', () => {
      const p = parseInt(input.value) / 1000;
      const v = logMap(p, min, max, curve);
      input.style.setProperty('--sl-pct', `${p * 100}%`);
      valEl.textContent = fmt(v);
      engine?.set(moduleId, param, v);
    });
  });

  // 슬라이더를 값으로 직접 설정 (Canvas 드래그 등 외부 제어)
  function setSliderByParam(param: string, v: number) {
    const s = sliderMap[param];
    if (!s) return;
    const p = Math.max(0, Math.min(1, toP(v, s.min, s.max, s.curve)));
    s.input.value = String(Math.round(p * 1000));
    s.input.style.setProperty('--sl-pct', `${p * 100}%`);
    s.valEl.textContent = s.fmt(v);
    engine?.set(moduleId, param, v);
  }

  // 전원 버튼
  const pwrBtn = el.querySelector<HTMLButtonElement>('.pwr-btn')!;
  const pwrDot = el.querySelector<HTMLElement>('.pwr-dot')!;
  const pwrLabel = el.querySelector<HTMLElement>('.pwr-label')!;

  pwrBtn.addEventListener('click', () => {
    const on = pwrBtn.getAttribute('aria-pressed') !== 'true';
    pwrBtn.setAttribute('aria-pressed', String(on));
    if (on) {
      pwrBtn.style.cssText = 'border-color:var(--color-violet);color:var(--color-violet);background:var(--color-violet-glow)';
      pwrDot.style.cssText = 'background:var(--color-violet);box-shadow:0 0 8px var(--color-violet)';
      pwrLabel.textContent = 'ON';
    } else {
      pwrBtn.style.cssText = '';
      pwrDot.style.cssText = 'background:var(--color-border)';
      pwrLabel.textContent = 'OFF';
    }
    engine?.setEnabled(moduleId, on);
  });

  // 타입 버튼
  el.querySelectorAll<HTMLButtonElement>('.type-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      el.querySelectorAll('.type-btn').forEach(b => {
        (b as HTMLElement).setAttribute('aria-pressed','false');
        (b as HTMLElement).style.cssText = '';
      });
      btn.setAttribute('aria-pressed','true');
      btn.style.cssText = 'background:white;color:var(--color-violet);box-shadow:0 1px 4px rgba(0,0,0,0.08)';
      engine?.set(moduleId, 'type', btn.dataset.val!);
    });
    // 기본 선택 스타일
    if (btn.getAttribute('aria-pressed') === 'true') {
      btn.style.cssText = 'background:white;color:var(--color-violet);box-shadow:0 1px 4px rgba(0,0,0,0.08)';
    }
  });

  // 추가 셀렉터 버튼 (Slope 등)
  el.querySelectorAll<HTMLElement>('.sel-group').forEach(group => {
    const param = group.dataset.selParam!;
    group.querySelectorAll<HTMLButtonElement>('.sel-btn').forEach(btn => {
      const sel = () => { btn.style.cssText = 'background:white;color:var(--color-violet);box-shadow:0 1px 4px rgba(0,0,0,0.08)'; };
      btn.addEventListener('click', () => {
        group.querySelectorAll('.sel-btn').forEach(b => { (b as HTMLElement).setAttribute('aria-pressed','false'); (b as HTMLElement).style.cssText = ''; });
        btn.setAttribute('aria-pressed','true'); sel();
        engine?.set(moduleId, param, btn.dataset.val!);
      });
      if (btn.getAttribute('aria-pressed') === 'true') sel();
    });
  });

  // 음원 버튼
  const waveRow = el.querySelector<HTMLElement>('.wave-row')!;
  el.querySelectorAll<HTMLButtonElement>('.src-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      el.querySelectorAll('.src-btn').forEach(b => {
        (b as HTMLElement).setAttribute('aria-pressed','false');
        (b as HTMLElement).style.cssText = '';
      });
      btn.setAttribute('aria-pressed','true');
      btn.style.cssText = 'background:white;color:var(--color-violet);box-shadow:0 1px 4px rgba(0,0,0,0.08)';
      waveRow.style.display = btn.dataset.src === 'tone' ? '' : 'none';
      engine?.setSource(btn.dataset.src as any);
    });
    if (btn.getAttribute('aria-pressed') === 'true') {
      btn.style.cssText = 'background:white;color:var(--color-violet);box-shadow:0 1px 4px rgba(0,0,0,0.08)';
    }
  });

  // 파형 버튼
  el.querySelectorAll<HTMLButtonElement>('.wave-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      el.querySelectorAll('.wave-btn').forEach(b => {
        (b as HTMLElement).setAttribute('aria-pressed','false');
        (b as HTMLElement).style.cssText = '';
      });
      btn.setAttribute('aria-pressed','true');
      btn.style.cssText = 'background:white;color:var(--color-violet);box-shadow:0 1px 4px rgba(0,0,0,0.08)';
      engine?.setWave(btn.dataset.wave as OscillatorType);
    });
    if (btn.getAttribute('aria-pressed') === 'true') {
      btn.style.cssText = 'background:white;color:var(--color-violet);box-shadow:0 1px 4px rgba(0,0,0,0.08)';
    }
  });

  // 재생 버튼
  const playBtn = el.querySelector<HTMLButtonElement>('.play-btn')!;
  const playDot = el.querySelector<HTMLElement>('.play-dot')!;
  const playLabel = el.querySelector<HTMLElement>('.play-label')!;

  playBtn.addEventListener('click', async () => {
    if (!engine) {
      engine = new Engine();
      // 레슨은 단일 이펙트: 인스턴스 1개 생성 (instanceId == type == moduleId)
      engine.addInstance(moduleId, moduleId);
      engine.updateChain([moduleId]);
      // 추천 소스/파형 적용
      engine.srcMode = defaultSrc;
      if (defaultSrc === 'tone') engine.wave = defaultWave;
      // 현재 슬라이더 값 엔진에 적용
      sliders.forEach(wrap => {
        const input = wrap.querySelector<HTMLInputElement>('input')!;
        const p = parseInt(input.value) / 1000;
        const min = parseFloat(wrap.dataset.min!);
        const max = parseFloat(wrap.dataset.max!);
        const curve = wrap.dataset.curve!;
        const v = logMap(p, min, max, curve);
        engine!.set(moduleId, wrap.dataset.param!, v);
      });
      // 전원 상태 적용 (기본 ON)
      const isOn = pwrBtn.getAttribute('aria-pressed') === 'true';
      engine.setEnabled(moduleId, isOn);
    }

    if (engine.playing) {
      engine.stop();
      playBtn.classList.remove('playing');
      playBtn.style.cssText = '';
      playDot.style.cssText = 'background:white';
      playLabel.textContent = '소리 켜기';
      stopViz();
    } else {
      await engine.start();
      playBtn.style.cssText = 'background:var(--color-surface-2);color:var(--color-ink-700);border:1px solid var(--color-border)';
      playDot.style.cssText = 'background:#ef4444;box-shadow:0 0 8px #ef4444';
      playLabel.textContent = '소리 끄기';
      startViz();
    }
  });

  // 이펙터별 기본 줌 레벨
  const DEFAULT_ZOOM: Record<string, number> = {
    drive: 192, tremolo: 1024, filter: 512, chorus: 512, delay: 512, reverb: 512,
  };
  let SCOPE_DRAW = DEFAULT_ZOOM[moduleId] ?? 512;
  const speedInput = el.querySelector<HTMLInputElement>('.scope-speed')!;
  const speedVal = el.querySelector<HTMLElement>('.scope-speed-val')!;
  speedInput.min = '128'; speedInput.max = '1024'; speedInput.step = '64';
  speedInput.value = String(SCOPE_DRAW);
  const initPct = (SCOPE_DRAW - 128) / (1024 - 128) * 100;
  speedInput.style.setProperty('--sl-pct', `${initPct}%`);
  speedVal.textContent = SCOPE_DRAW <= 256 ? '확대' : SCOPE_DRAW >= 768 ? '축소' : '보통';
  speedInput.addEventListener('input', () => {
    SCOPE_DRAW = parseInt(speedInput.value);
    speedInput.style.setProperty('--sl-pct', `${(SCOPE_DRAW-128)/(1024-128)*100}%`);
    speedVal.textContent = SCOPE_DRAW <= 256 ? '확대' : SCOPE_DRAW >= 768 ? '축소' : '보통';
  });

  // 비주얼라이저
  const scopeCv = el.querySelector<HTMLCanvasElement>('.scope-canvas')!;
  const specCv = el.querySelector<HTMLCanvasElement>('.spectrum-canvas')!;
  const envCv = el.querySelector<HTMLCanvasElement>('.envelope-canvas') ?? null;
  let scopeCtx: CanvasRenderingContext2D;
  let specCtx: CanvasRenderingContext2D;
  let envCtx: CanvasRenderingContext2D | null = null;
  let rafId = 0;

  // 엔벨로프 링버퍼 (Delay/Reverb용)
  const ENV_LEN = 300;
  const envBuf = new Float32Array(ENV_LEN);
  let envHead = 0;

  // Phase 3: Filter 스펙트럼 캔버스 드래그 → Cutoff(가로)/Resonance(세로)
  if (moduleId === 'filter') {
    specCv.style.cursor = 'crosshair';
    let dragging = false;
    const applyXY = (clientX: number, clientY: number) => {
      const r = specCv.getBoundingClientRect();
      const x = Math.max(0, Math.min(1, (clientX - r.left) / r.width));
      const y = Math.max(0, Math.min(1, (clientY - r.top) / r.height));
      const fs = sliderMap.freq, qs = sliderMap.q;
      const nyq = ((engine as any)?.ctx?.sampleRate || 44100) / 2;
      // 스펙트럼 막대의 quadratic 매핑과 일치: freq = x² · nyquist
      const freq = Math.max(fs.min, Math.min(fs.max, x * x * nyq));
      const q = qs.min * Math.pow(qs.max / qs.min, 1 - y); // 위로 갈수록 Q ↑
      setSliderByParam('freq', freq);
      setSliderByParam('q', q);
    };
    specCv.addEventListener('pointerdown', e => { dragging = true; specCv.setPointerCapture(e.pointerId); applyXY(e.clientX, e.clientY); });
    specCv.addEventListener('pointermove', e => { if (dragging) applyXY(e.clientX, e.clientY); });
    const end = () => { dragging = false; };
    specCv.addEventListener('pointerup', end);
    specCv.addEventListener('pointercancel', end);
  }

  function setupCv(cv: HTMLCanvasElement) {
    const dpr = window.devicePixelRatio || 1;
    const ctx = cv.getContext('2d')!;
    const fit = () => {
      const r = cv.getBoundingClientRect();
      cv.width = r.width * dpr; cv.height = r.height * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };
    fit(); window.addEventListener('resize', fit);
    return ctx;
  }

  function startViz() {
    scopeCtx = setupCv(scopeCv);
    specCtx = setupCv(specCv);
    if (envCv) envCtx = setupCv(envCv);
    const loop = () => {
      rafId = requestAnimationFrame(loop);
      drawScope(); drawSpec();
      if (envCtx) drawEnvelope();
    };
    loop();
  }

  function stopViz() { cancelAnimationFrame(rafId); }
  function cssW(cv: HTMLCanvasElement) { return cv.width / (window.devicePixelRatio || 1); }
  function cssH(cv: HTMLCanvasElement) { return cv.height / (window.devicePixelRatio || 1); }

  function drawScope() {
    const w = cssW(scopeCv), h = cssH(scopeCv), ctx = scopeCtx;

    // Chorus: 잔상 효과 (반투명 덮기)
    if (moduleId === 'chorus') {
      ctx.fillStyle = 'rgba(240,240,248,0.18)';
      ctx.fillRect(0, 0, w, h);
    } else {
      ctx.clearRect(0, 0, w, h);
      ctx.fillStyle = '#f0f0f8';
      ctx.fillRect(0, 0, w, h);
    }

    if (!engine?.playing) return;
    const data = engine.getScope();
    const bufLen = data.length;
    const N = Math.min(SCOPE_DRAW, bufLen - 1);

    // 제로 크로싱 트리거
    let start = 0;
    for (let i = 1; i < bufLen - N; i++) {
      if (data[i - 1] < 128 && data[i] >= 128) { start = i; break; }
    }

    ctx.lineWidth = moduleId === 'chorus' ? 1.2 : 1.5;
    ctx.strokeStyle = '#7c3aed';
    ctx.shadowColor = 'rgba(124,58,237,0.6)'; ctx.shadowBlur = 5;
    ctx.beginPath();
    for (let i = 0; i < N; i++) {
      const x = i / (N - 1) * w, y = (1 - data[start + i] / 255) * h;
      i ? ctx.lineTo(x, y) : ctx.moveTo(x, y);
    }
    ctx.stroke(); ctx.shadowBlur = 0;
  }

  function drawSpec() {
    if (!specCv) return;
    const w = cssW(specCv), h = cssH(specCv), ctx = specCtx;
    ctx.clearRect(0, 0, w, h);
    ctx.fillStyle = '#f0f0f8'; ctx.fillRect(0, 0, w, h);
    if (!engine?.playing) return;
    const data = engine.getSpectrum(), N = data.length, bars = 48;
    const grad = ctx.createLinearGradient(0, h, 0, 0);
    grad.addColorStop(0, '#2563eb'); grad.addColorStop(1, '#60a5fa');
    ctx.fillStyle = grad;
    ctx.shadowColor = 'rgba(37,99,235,0.4)'; ctx.shadowBlur = 4;
    for (let i = 0; i < bars; i++) {
      const f0 = Math.pow(i / bars, 2), f1 = Math.pow((i + 1) / bars, 2);
      const lo = Math.floor(f0 * N), hi = Math.max(lo + 1, Math.floor(f1 * N));
      let mx = 0; for (let j = lo; j < hi && j < N; j++) mx = Math.max(mx, data[j]);
      const bh = (mx / 255) * (h - 4);
      ctx.fillRect(i * w / bars + 0.5, h - bh, w / bars - 1, bh);
    }
    ctx.shadowBlur = 0;

    // Filter: Cutoff 가이드라인 오버레이
    if (moduleId === 'filter') {
      const freqWrap = el.querySelector<HTMLElement>('.slider-wrap[data-param="freq"]');
      if (freqWrap) {
        const inp = freqWrap.querySelector<HTMLInputElement>('input')!;
        const p = parseInt(inp.value) / 1000;
        const minF = parseFloat(freqWrap.dataset.min!), maxF = parseFloat(freqWrap.dataset.max!);
        const freq = minF * Math.pow(maxF / minF, p); // log mapping
        const nyquist = (engine as any).ctx.sampleRate / 2;
        const normF = freq / nyquist;
        // 스펙트럼 bars quadratic 역매핑: x = sqrt(normF) * bars
        const barIdx = Math.sqrt(normF) * bars;
        const xPos = barIdx / bars * w;
        // 가이드라인
        ctx.save();
        ctx.strokeStyle = 'rgba(124,58,237,0.9)';
        ctx.lineWidth = 2;
        ctx.setLineDash([4, 3]);
        ctx.beginPath(); ctx.moveTo(xPos, 0); ctx.lineTo(xPos, h); ctx.stroke();
        ctx.setLineDash([]);
        // 레이블
        const label = freq >= 1000 ? (freq/1000).toFixed(1)+'kHz' : Math.round(freq)+'Hz';
        ctx.fillStyle = 'rgba(124,58,237,0.9)';
        ctx.font = '9px JetBrains Mono, monospace';
        ctx.fillText(label, Math.min(xPos + 3, w - 36), 12);
        ctx.restore();
      }
    }
  }

  // 엔벨로프 스크롤 뷰 (Delay/Reverb)
  function drawEnvelope() {
    if (!envCtx || !envCv) return;
    const w = cssW(envCv), h = cssH(envCv), ctx = envCtx;

    // 현재 피크 계산 후 링버퍼에 추가
    if (engine?.playing) {
      const d = engine.getScope();
      let peak = 0;
      for (let i = 0; i < d.length; i++) peak = Math.max(peak, Math.abs(d[i] - 128) / 128);
      envBuf[envHead % ENV_LEN] = peak;
      envHead++;
    }

    ctx.clearRect(0, 0, w, h);
    ctx.fillStyle = '#f0f0f8'; ctx.fillRect(0, 0, w, h);

    // 그리드 가로선
    ctx.strokeStyle = moduleId === 'delay' ? 'rgba(124,58,237,0.08)' : 'rgba(37,99,235,0.08)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(0, h * 0.5); ctx.lineTo(w, h * 0.5);
    ctx.stroke();

    if (!engine?.playing) return;

    const color = moduleId === 'delay' ? '#7c3aed' : '#2563eb';
    ctx.strokeStyle = color;
    ctx.shadowColor = moduleId === 'delay' ? 'rgba(124,58,237,0.5)' : 'rgba(37,99,235,0.5)';
    ctx.shadowBlur = 4;
    ctx.lineWidth = 1.5;
    ctx.beginPath();
    for (let i = 0; i < ENV_LEN; i++) {
      const idx = (envHead - ENV_LEN + i + ENV_LEN * 2) % ENV_LEN;
      const x = i / (ENV_LEN - 1) * w;
      const y = h - envBuf[idx] * (h - 4) - 2;
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.stroke(); ctx.shadowBlur = 0;
  }
});
</script>
