---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { HUB_META, HUBS } from '../../content.config';

const all = (await getCollection('topics')).filter(t => !t.data.draft);
const hubs = [...HUBS]
  .sort((a, b) => HUB_META[a].order - HUB_META[b].order)
  .map(h => ({
    id: h,
    ...HUB_META[h],
    count: all.filter(t => t.data.hub === h).length,
  }));
const base = import.meta.env.BASE_URL;
---
<Base title="지식 허브" description="소리·음향·오디오 엔지니어링의 모든 지식을 인터랙티브하게 탐구하세요.">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">

    <div class="mb-10">
      <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">Knowledge Hub</span>
      <h1 class="text-3xl sm:text-4xl font-bold mt-2 mb-2" style="font-family:'Space Grotesk','Pretendard',sans-serif">지식 허브</h1>
      <p class="text-lg text-[var(--color-ink-500)]">소리의 물리부터 믹싱까지 — 아래 추천 순서대로 따라가며 익히세요</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {hubs.map((h, i) => {
        const ready = h.count > 0;
        const inner = (
          <>
            <div class="flex items-baseline justify-between mb-2">
              <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-ink-300)]">{h.label}</span>
              {ready
                ? <span class="text-[10px] font-mono text-[var(--color-violet)]">{h.count}개 토픽</span>
                : <span class="text-[10px] font-mono px-2 py-0.5 rounded-full bg-[var(--color-surface-2)] text-[var(--color-ink-300)]">준비 중</span>}
            </div>
            <h2 class="flex items-center gap-2 font-bold text-xl mb-1" style="font-family:'Space Grotesk','Pretendard',sans-serif">
              <span class={`w-7 h-7 rounded-lg flex items-center justify-center text-xs font-mono font-bold flex-none ${ready ? 'gradient-brand text-white' : 'bg-[var(--color-surface-2)] text-[var(--color-ink-300)]'}`}>{String(i + 1).padStart(2, '0')}</span>
              {h.kr}
            </h2>
            <p class="text-sm text-[var(--color-ink-500)]">{h.desc}</p>
          </>
        );
        return ready ? (
          <a href={`${base}learn/${h.id}/`}
            class="group p-5 rounded-2xl border border-[var(--color-border)] bg-white hover:border-[var(--color-violet)] hover:-translate-y-0.5 transition-all">
            {inner}
          </a>
        ) : (
          <div class="p-5 rounded-2xl border border-dashed border-[var(--color-border)] bg-[var(--color-surface)] opacity-70">
            {inner}
          </div>
        );
      })}
    </div>
  </div>
</Base>
