---
import Base from '../layouts/Base.astro';
import { MODULES } from '../lib/modules';
const base = import.meta.env.BASE_URL;
---
<Base title="홈" description="Web Audio API로 배우는 사운드 이펙트 실습 플레이그라운드. 필터·드라이브·딜레이·리버브를 직접 조작하며 소리가 바뀌는 원리를 배웁니다.">

  <!-- Hero -->
  <section class="relative max-w-6xl mx-auto px-4 sm:px-6 pt-20 pb-16 text-center overflow-hidden">
    <!-- 배경 글로우 -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full pointer-events-none"
      style="background: radial-gradient(ellipse, rgba(124,58,237,0.1) 0%, rgba(37,99,235,0.06) 50%, transparent 70%);">
    </div>

    <div class="relative">
      <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-mono font-medium mb-6
        border border-[var(--color-violet-light)] bg-[var(--color-violet-glow)] text-[var(--color-violet)]">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-violet)] animate-pulse"></span>
        Web Audio API · 무설치 · 무료
      </span>

      <h1 class="text-4xl sm:text-6xl font-bold tracking-tight mb-5 leading-tight" style="font-family:'Space Grotesk'">
        소리를 <span class="gradient-brand-text">직접 만지며</span><br/>배우는 이펙트
      </h1>

      <p class="text-lg text-[var(--color-ink-500)] max-w-xl mx-auto mb-10 leading-relaxed">
        노브를 돌리면 파형과 주파수가 실시간으로 바뀝니다.<br/>
        보고 듣고 느끼며 사운드 엔지니어링을 익히세요.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href={`${base}learn/filter/`}
          class="gradient-brand text-white font-semibold px-7 py-3 rounded-xl text-[15px] transition hover:opacity-90 hover:-translate-y-0.5 shadow-lg"
          style="font-family:'Space Grotesk'; box-shadow: 0 8px 30px -8px rgba(124,58,237,0.5)">
          레슨 시작하기 →
        </a>
        <a href={`${base}sandbox/`}
          class="border border-[var(--color-border)] text-[var(--color-ink-700)] font-semibold px-7 py-3 rounded-xl text-[15px] transition hover:border-[var(--color-violet)] hover:text-[var(--color-violet)] bg-white"
          style="font-family:'Space Grotesk'">
          샌드박스 열기
        </a>
      </div>
    </div>
  </section>

  <!-- 이펙트 카드 그리드 -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-20">
    <div class="flex items-baseline gap-3 mb-8">
      <h2 class="text-xl font-bold" style="font-family:'Space Grotesk'">6가지 이펙트 레슨</h2>
      <span class="text-sm text-[var(--color-ink-300)] font-mono">각 카드를 클릭해 인터랙티브 레슨을 시작하세요</span>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {MODULES.map((m) => (
        <a href={`${base}learn/${m.id}/`}
          class="group block p-5 rounded-2xl border border-[var(--color-border)] bg-white hover:border-transparent transition-all duration-200"
          style={`--hover-color: ${m.color === 'violet' ? 'rgba(124,58,237,0.4)' : 'rgba(37,99,235,0.4)'}`}
          onmouseover="this.style.boxShadow=`0 0 0 1.5px var(--hover-color), 0 8px 30px -10px var(--hover-color)`"
          onmouseout="this.style.boxShadow=''"
        >
          <div class="flex items-start justify-between mb-3">
            <div class={`w-9 h-9 rounded-xl flex items-center justify-center text-sm font-mono font-bold text-white ${m.color === 'violet' ? 'gradient-brand' : ''}`}
              style={m.color === 'blue' ? 'background: linear-gradient(135deg,#2563eb,#7c3aed)' : ''}>
              {m.num}
            </div>
            <span class={`text-xs font-mono px-2 py-0.5 rounded-full border ${
              m.color === 'violet'
                ? 'border-[var(--color-violet-light)] text-[var(--color-violet)] bg-[var(--color-violet-glow)]'
                : 'border-[var(--color-blue-light)] text-[var(--color-blue)] bg-[var(--color-blue-glow)]'
            }`}>{m.kr}</span>
          </div>

          <h3 class="font-bold text-lg mb-1 group-hover:gradient-brand-text transition" style="font-family:'Space Grotesk'">{m.name}</h3>
          <p class="text-sm text-[var(--color-ink-500)] mb-4 leading-relaxed">{m.tagline}</p>

          <div class="flex items-center gap-1.5 flex-wrap">
            {m.knobs.map(k => (
              <span class="text-[11px] font-mono px-2 py-0.5 bg-[var(--color-surface)] rounded-md text-[var(--color-ink-500)]">
                {k.label}
              </span>
            ))}
            {m.type && (
              <span class="text-[11px] font-mono px-2 py-0.5 bg-[var(--color-surface)] rounded-md text-[var(--color-ink-500)]">
                Type
              </span>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- 특징 섹션 -->
  <section class="border-t border-[var(--color-border)] bg-[var(--color-surface)]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
      <h2 class="text-xl font-bold text-center mb-10" style="font-family:'Space Grotesk'">왜 SoundLab인가요?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {[
          { icon: '🎛️', title: '즉각적인 피드백', desc: '슬라이더를 움직이면 파형과 스펙트럼이 실시간으로 반응합니다.' },
          { icon: '📖', title: '개념 내장 학습', desc: '각 이펙트마다 원리 설명과 "들어볼 것 / 볼 것" 가이드가 내장되어 있습니다.' },
          { icon: '🔗', title: '설치 없이 즉시 시작', desc: '브라우저만 있으면 됩니다. 앱 설치, 회원가입 없이 링크 하나로 실습합니다.' },
        ].map(f => (
          <div class="p-5 rounded-2xl bg-white border border-[var(--color-border)]">
            <div class="text-2xl mb-3">{f.icon}</div>
            <h3 class="font-semibold mb-2" style="font-family:'Space Grotesk'">{f.title}</h3>
            <p class="text-sm text-[var(--color-ink-500)] leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</Base>
